@paradigm oop

struct Dog {
    sound: int64,
}

struct Cat {
    sound: int64,
}

interface Animal {
    speak() -> int64
}

impl Animal for Dog {
    func speak() -> int64 {
        return self.sound
    }
}

impl Animal for Cat {
    func speak() -> int64 {
        return self.sound
    }
}

func describe(a: Animal) -> int64 {
    return a.speak()
}

func main() -> int32 {
    d := Dog { sound: 70 }
    c := Cat { sound: 99 }
    println(describe(d))
    println(describe(c))
    return 0
}
