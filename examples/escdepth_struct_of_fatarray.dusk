// A struct field whose TYPE is a fat fixed array. The walk descends through the
// struct field into the array elements, so a slice element viewing a local is
// caught at depth.
@paradigm procedural
struct G { grid: int64[][2] }
func mk() -> G {
    a: int64[3] = [1, 2, 3]
    return G { grid: [a[0..2], a[0..1]] }
}
func main() -> int32 {
    g := mk()
    println(g.grid[0][0])
    return 0
}
