// W2 reject twin: `Result.Err("too big")` carries no T payload, and nothing
// here pins it, so the binding cannot infer T. Compare resulthelpers.dusk,
// where every ctor is pinned by an annotation or by a plain, T-bearing
// argument (result_ok, result_from).
@paradigm procedural

@import std.functional.result

func main() -> int32 {
    x := Result.Err("too big")
    match x {
        Ok(v) => println("ok"),
        Err(e) => println("err"),
    }
    return 0
}
