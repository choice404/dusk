// A mut tuple binding reassigned to an escaping value. t starts clean, holding a
// param slice, then is reassigned to a frame-local array tuple; the reassignment
// updates the escape flag, so returning t is rejected.
@paradigm procedural
func mk(xs: int64[]) -> (int64[], int64) {
    mut t := (xs, 5)
    t = ([1, 2, 3], 9)
    return t
}
func main() -> int32 {
    data: int64[3] = [10, 20, 30]
    s, n := mk(data[0..3])
    println(s[0])
    println(n)
    return 0
}
