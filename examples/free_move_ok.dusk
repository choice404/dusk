@paradigm procedural

// move hands its argument straight back as the caller's own value, so freeing the
// result of a move is freeing the same owner under a different spelling. The
// container-read rule condemns only a value read back out of a container's storage,
// which move never does, so free(move(p)) stays legal.
func main() -> int32 {
    p: *int64 = alloc(7)
    free(move(p))
    println(0)
    return 0
}
