@paradigm procedural

// A use after free. The first dereference is valid and prints 42. After the
// free, the pointer's remembered generation no longer matches the header, so
// the second dereference faults instead of reading freed memory.
func main() -> int32 {
    p: *int64 = alloc(42)
    println(*p)
    free(p)
    println(*p)
    return 0
}
