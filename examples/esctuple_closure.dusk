// A local-capturing closure buried in a returned tuple. add captures base, a
// local of mk, so the tuple member's environment sits on mk's frame; returning
// the tuple escapes and is rejected member by member.
@paradigm procedural
@paradigm functional
func mk() -> ((int64) -> int64, int64) {
    base: int64 = 100
    add := lambda (x: int64) -> int64 { return x + base }
    return (add, 7)
}
func main() -> int32 {
    f, n := mk()
    println(f(5))
    println(n)
    return 0
}
