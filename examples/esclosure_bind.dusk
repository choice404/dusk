// A closure escaping through a named binding. add captures base, a local of mk,
// so its environment sits on mk's frame; returning the binding, not just a
// lambda literal, still escapes and is rejected.
@paradigm procedural
@paradigm functional
func mk() -> (int64) -> int64 {
    base: int64 = 100
    add := lambda (x: int64) -> int64 { return x + base }
    return add
}
func main() -> int32 {
    f := mk()
    println(f(5))
    return 0
}
