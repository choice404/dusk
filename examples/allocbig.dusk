// alloc() with no value sizes the block from the declared pointer type, so a
// struct wider than one word is fully allocated. Writing its last field lands
// inside the block, and a later allocation stays intact.
struct Big {
    a: int64,
    b: int64,
    c: int64,
    d: int64,
}

func main() -> int32 {
    p: *Big = alloc()
    (*p).a = 1
    (*p).d = 4
    q: *int64 = alloc(7)
    println((*p).a)
    println((*p).d)
    println(*q)
    free(q)
    free(p)
    return 0
}
