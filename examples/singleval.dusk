@paradigm procedural

// AssignOp computes its place address, including any index expression, exactly
// once: pick() prints 9 a single time even though it appears once as the index
// of a compound assignment.
func pick() -> int64 {
    println(9)
    return 1
}

func main() -> int32 {
    mut xs: int64[3] = [10, 20, 30]
    xs[pick()] += 5
    println(xs[1])
    xs[0]++
    println(xs[0])
    return 0
}
