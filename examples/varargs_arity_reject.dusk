@paradigm procedural

// A variadic call must still supply every fixed parameter. Here two are declared
// but only one is passed, so the checker reports the shortfall.
foreign "C" {
    func cvararg(a: int64, b: int64, ...) -> int64
}

func main() -> int64 {
    r: int64 = cvararg(1)
    println(r)
    return 0
}
