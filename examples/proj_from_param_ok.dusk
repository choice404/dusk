// The no-over-reject: projecting a slice field out of a struct built from a
// param slice is legal, since the caller owns the backing. Must build and run.
@paradigm procedural
struct W { rows: int64[] }
func mk(xs: int64[]) -> int64[] {
    s := W { rows: xs }
    return s.rows
}
func main() -> int32 {
    d: int64[3] = [10, 20, 30]
    r := mk(d[0..3])
    println(r[0])
    return 0
}
