// FIX-3: an annotated array threads its element type to each element, so the
// trailing `Opt.None` instantiates at float64 alongside its typed sibling.
@paradigm procedural

enum Opt<T> {
    Some(v: T),
    None,
}

func main() -> int32 {
    xs: Opt<float64>[2] = [Opt.Some(1.5), Opt.None]
    match xs[1] {
        Some(v) => println("some"),
        None => println("none"),
    }
    return 0
}
