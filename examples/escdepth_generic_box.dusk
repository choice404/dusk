// A generic struct field whose concrete type argument is a slice viewing a
// frame local. The declared field type erases to a type parameter, so the walk
// falls back to the initializer's dataflow to catch the local view.
@paradigm procedural
struct Box<T> { v: T }
func mk() -> Box<int64[]> {
    a: int64[3] = [111, 222, 333]
    return Box { v: a[0..3] }
}
func main() -> int32 {
    b := mk()
    println(b.v[0])
    return 0
}
