@paradigm procedural

// A foreign signature sits on the raw pointer layer only, so a string, typed
// apart from a raw pointer, cannot cross the C boundary directly. This is why
// std.os copies a string into a *raw char buffer before every C call. The
// declaration is rejected at check time.
foreign "C" {
    func puts(s: string) -> int32
}

func main() -> int32 {
    return 0
}
