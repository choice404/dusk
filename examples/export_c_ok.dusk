@paradigm procedural

@import std.io

// A dusk function marked export "C" keeps its bare symbol for a C host to call.
// It is also an ordinary function dusk code can call, which this program does to
// prove an export compiles and runs inside a normal binary.
export "C" func lib_add(a: int64, b: int64) -> int64 {
    return a + b
}

export "C" func lib_scale(x: float64, k: float64) -> float64 {
    return x * k
}

func main() -> int32 {
    println(lib_add(20, 22))
    return 0
}
