@paradigm procedural

// A generic owning func at a non-pointer instantiation is inert. The marker only
// classifies a managed pointer result as an owner, so at int64 the result is an
// ordinary value: it copies freely and never false-rejects as an owning pointer.
owning func take_id<T>(x: T) -> T {
    return x
}

func main() -> int32 {
    n: int64 = take_id(41)
    m: int64 = n
    println(n)
    println(m)
    return 0
}
