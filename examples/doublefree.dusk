@paradigm procedural

// A double free. The first free bumps the block's generation, so the second
// free sees a generation mismatch and faults, the same generation check a
// dereference runs. A stale pointer faults at the free, not after it corrupts.
func main() -> int32 {
    p: *int64 = alloc(5)
    println(*p)
    free(p)
    free(p)
    return 0
}
