// Spec audit: a string is immutable, so an element store `s[0] = 'H'` has no
// writable place and is rejected, naming the StringBuilder as the fix, instead
// of faulting on a store into read-only memory at run time.
@paradigm procedural

func main() -> int32 {
    mut s := "hello"
    s[0] = 'H'
    println(s)
    return 0
}
