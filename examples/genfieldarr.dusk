// A generic struct field typed as a fixed scalar array, `Box<int64[3]>`, used to
// be wrongly rejected; this pins the fix. The field holds the array whole and
// indexing it reads the second element.

struct Box<T> {
    v: T,
}

func main() -> int32 {
    b: Box<int64[3]> = Box { v: [1, 2, 3] }
    println(b.v[1])
    return 0
}
