@paradigm procedural

// xs[a..=b] is xs[a..b+1]: 1..=3 keeps three elements, 2..=1 is empty since
// the +1 lands before the lo <= hi check, and 0..=4 is the whole array.
func sum(s: int64[]) -> int64 {
    mut total: int64 = 0
    mut i: int64 = 0
    while i < s.len {
        total += s[i]
        i++
    }
    return total
}

func main() -> int32 {
    xs: int64[5] = [1, 2, 3, 4, 5]
    println(sum(xs[1..=3]))
    println(sum(xs[2..=1]))
    println(sum(xs[0..=4]))
    return 0
}
