@paradigm procedural

// Pins the precedence ladder: shifts sit between & and +, & binds tighter than
// ^ which binds tighter than |, ** binds tighter than *, and a bitwise AND
// used in a condition groups before the comparison.
func main() -> int32 {
    println(1 + 2 << 3)
    println(1 << 2 + 3)
    println(4 | 2 ^ 3 & 1)
    println(2 * 3 ** 2)
    if (1 & 3) == 1 {
        println(1)
    } else {
        println(0)
    }
    println(7 & 1 + 1)
    return 0
}
