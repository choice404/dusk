// An escaping slice tuple laundered through an alias chain. b aliases a, which
// binds a frame-local array slice tuple; the escape flag propagates through the
// alias, so returning b is rejected.
@paradigm procedural
func mk() -> (int64[], int64) {
    a := ([1, 2, 3], 42)
    b := a
    return b
}
func main() -> int32 {
    s, n := mk()
    println(s[0])
    println(n)
    return 0
}
