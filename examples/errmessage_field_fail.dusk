// M2 reject twin: an error carries only `message`. Reaching for any other field
// is rejected in sema, not papered over as a silent zero from codegen.
@paradigm procedural

func fail() -> (int64, error) {
    return (0, error { message: "boom" })
}

func main() -> int32 {
    v, e := fail()
    println(v)
    n := e.code
    println(n)
    e.ignore()
    return 0
}
