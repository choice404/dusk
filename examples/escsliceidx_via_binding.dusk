// A slice-index projection laundered through a binding. r aliases an element of
// a local array of slices; the escape flag propagates, so returning r is rejected.
@paradigm procedural
func mk() -> int64[] {
    a: int64[3] = [1, 2, 3]
    grid: int64[][2] = [a[0..2], a[0..1]]
    r := grid[0]
    return r
}
func main() -> int32 {
    z := mk()
    println(z[0])
    return 0
}
