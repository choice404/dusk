@paradigm procedural
@import std.async.future

// async_run is the sync-to-async bridge; inside an async func it makes no
// sense, since the enclosing task frame can just await the call instead.
async func g() -> int64 {
    return 1
}

async func amain() -> int64 {
    r := async_run(g())
    return r
}

func main() -> int32 {
    r := async_run(amain())
    println(r)
    return 0
}
