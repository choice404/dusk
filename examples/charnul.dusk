// An embedded NUL is an ordinary byte to a char array: the literal copy
// carries it and the byte counted printer writes through it, while the plain
// heap string keeps its C string reading and stops there.
@paradigm procedural

func main() -> int32 {
    u: char[3] = "x\u{0}y"
    b0: int64 = u[0]
    b1: int64 = u[1]
    b2: int64 = u[2]
    println("{} {} {}", b0, b1, b2)
    t := "x\u{0}y"
    println(t)
    return 0
}
