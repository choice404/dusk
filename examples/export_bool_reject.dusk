@paradigm procedural

// An exported C function cannot take or return bool: a dusk bool lowers to an
// LLVM i1, which no C header type spells without a byte-vs-bit mismatch. Use char
// or int8, which cross as a full byte.
export "C" func lib_flag(b: bool) -> int64 {
    if b {
        return 1
    }
    return 0
}
