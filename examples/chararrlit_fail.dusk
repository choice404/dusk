// Compile-fail twin of chararrlit: the literal's byte length must equal the
// array length exactly. "héllo" is six bytes, so a char[5] refuses it with
// the byte count named; no padding and no truncation.
@paradigm procedural

func main() -> int32 {
    u: char[5] = "héllo"
    println(u)
    return 0
}
