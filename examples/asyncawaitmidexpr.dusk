@paradigm procedural
@import std.async.future

// 'await' is a statement-position suspension, not an operator. Burying it in
// an arithmetic expression has no place to park the value, so it is rejected
// even though f is a legally minted future.
async func amain() -> int64 {
    f: Future<int64> = future_new()
    x := 1 + await f
    return x
}

func main() -> int32 {
    r := async_run(amain())
    println(r)
    return 0
}
