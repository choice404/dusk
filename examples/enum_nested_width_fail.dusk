// FIX-E reject twin: the outer ctor threads `Opt<int32>` as the inner payload's
// expected, but a declared int64 value does not fit an int32 slot. The ground
// type re-check names the mismatch instead of letting the nested payload relabel.
@paradigm procedural

enum Opt<T> {
    Some(v: T),
    None,
}

func main() -> int32 {
    n: int64 = 5
    x: Opt<Opt<int32>> = Opt.Some(Opt.Some(n))
    match x {
        Some(v) => println("some"),
        None => println("none"),
    }
    return 0
}
