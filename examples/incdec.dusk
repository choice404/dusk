@paradigm procedural

// ++ and -- are statement only postfix forms desugared to a compound
// assignment with literal 1, so an int8 place wraps exactly like `+ 1` does.
func main() -> int32 {
    mut i: int64 = 5
    i++
    i++
    i--
    println(i)

    mut c: int8 = 126
    c++
    c++
    println(c)

    mut xs: int64[2] = [5, 2]
    xs[1]--
    println(xs[1])
    return 0
}
