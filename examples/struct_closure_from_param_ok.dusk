// A struct holding a closure field that captures nothing frame-local, only its
// own parameter, so it is a plain function pointer safe to return in a struct.
// Must build and run.
@paradigm procedural
@paradigm functional
struct Holder { f: (int64) -> int64 }
func mk() -> Holder {
    return Holder { f: lambda (x: int64) -> int64 { return x + 1 } }
}
func main() -> int32 {
    h := mk()
    println(h.f(5))
    return 0
}
