@paradigm procedural
@import std.async.future

// The err word of a two-bind await is a pending error like any other; it must
// be inspected, checked, or discarded before the func returns.
async func g() -> int64 {
    return 1
}

async func amain() -> int64 {
    x, e := await g()
    return x
}

func main() -> int32 {
    r := async_run(amain())
    println(r)
    return 0
}
