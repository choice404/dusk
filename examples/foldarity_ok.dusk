// Accept twin of foldarity_fail: fold at its correct arity of three, a
// collection, a seed, and a folding function, sums the slice.
@paradigm procedural
@paradigm functional

func main() -> int32 {
    xs: int64[3] = [1, 2, 3]
    r := fold(xs[0..3], 0, lambda (acc: int64, x: int64) -> int64 { return acc + x })
    println(r)
    return 0
}
