// Accept twin of enummethod_fail: the free-function form over an enum value is
// the supported spelling, so `is_some(m)` type-checks and runs.
@paradigm procedural

enum Maybe {
    Just(v: int64),
    Nothing,
}

func is_some(m: Maybe) -> bool {
    match m {
        Just(v) => return true,
        Nothing => return false,
    }
}

func main() -> int32 {
    m := Maybe.Just(5)
    if is_some(m) {
        println(1)
    }
    return 0
}
