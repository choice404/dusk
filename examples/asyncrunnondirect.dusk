@paradigm procedural
@import std.async.future

// async_run takes a direct call of an async func, written at the call site.
// A stored future does not carry which async func minted it, so it is
// rejected even when the future genuinely came from one.
async func g() -> int64 {
    return 1
}

func main() -> int32 {
    fa := g()
    r := async_run(fa)
    println(r)
    return 0
}
