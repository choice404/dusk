@paradigm procedural

// The void await form discards its value; it is only legal when the awaited
// element is void. g returns int64, so the value must be bound.
async func g() -> int64 {
    return 1
}

async func amain() -> int64 {
    await g()
    return 1
}

func main() -> int32 {
    r := async_run(amain())
    println(r)
    return 0
}
