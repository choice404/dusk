// Accept twin of ctorfit_fail: the signed-int32 maximum fits its payload, and an
// int8 binding at its signed maximum fits too, so both are accepted and print.
@paradigm procedural

enum E {
    Has(v: int32),
    Nope,
}

func main() -> int32 {
    e := E.Has(2147483647)
    match e {
        Has(v) => println(v),
        Nope   => println(0),
    }
    x: int8 = 127
    println(x)
    return 0
}
