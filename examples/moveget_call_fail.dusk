@paradigm procedural
@import std.vector

// move of a container read is refused for the same reason free is: vec_get hands back
// a value the container still holds, so moving it out forges an owner the map has no
// record of. vec_take is the sanctioned removal.
func main() -> int32 {
    v: *Vector<*int64> = alloc(vec_new())
    vec_push(v, alloc(10))
    x: *int64 = move(vec_get(v, 0))
    println(*x)
    vec_free(v)
    free(v)
    return 0
}
