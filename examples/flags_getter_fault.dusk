// Reading a flag through the wrong-kind getter is a program bug, so std.flags
// faults and aborts. Here a bool flag is read with the integer getter.
@paradigm procedural

@import std.flags

func main() -> int32 {
    f: *Flags = alloc(flags_new("greet", "a greeting demo"))
    flag_bool(f, "verbose", "print more")
    println(flag_get_int(f, "verbose"))
    return 0
}
