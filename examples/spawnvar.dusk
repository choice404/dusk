// spawn needs a lambda literal at the call site, since only the literal knows
// the environment layout the runtime heap-copies. A closure variable is two
// opaque words. This program does not compile.
func main() -> int32 {
    f := lambda () -> void {
        println("hi")
    }
    t, e := spawn(f)
    e.ignore()
    je := join(t)
    je.ignore()
    return 0
}
