@paradigm procedural

// An owning declaration promises a value whose free the generation check can
// judge. A raw pointer carries no generation, so the marker would be an
// unbackstopped lie the runtime could never catch; the declaration rejects.
owning func grab(n: int64) -> *raw int64 {
    return alloc_bytes(n)
}

func main() -> int64 {
    p: *raw int64 = grab(8)
    free(p)
    return 0
}
