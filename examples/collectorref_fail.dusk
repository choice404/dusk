@paradigm procedural

struct Point {
    x: int64,
    y: int64,
}

// A collected value is not owned, so a `ref` alias is meaningless. The accept
// twin is a plain copy, `d := c`, as in collectorbox.dusk.
func main() -> int32 {
    c := collector<Point>(Point { x: 1, y: 2 })
    ref r := c
    println((*r).x)
    return 0
}
