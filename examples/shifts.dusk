@paradigm procedural

// Shl and ashr, including negative operands, the 62/63 boundary on int64, a
// dynamic (non constant) amount, and int8 wraparound.
func main() -> int32 {
    println(1 << 3)
    println(5 << 1)
    println(-16 >> 2)
    println(-1 >> 63)
    println(1 << 62)
    n: int64 = 3
    println(1 << n)
    c: int8 = 1
    println(c << 7)
    return 0
}
