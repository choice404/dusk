// FIX-3: an assignment threads the target's type as the value's expected, so
// `x = Opt.None` into a `mut x: Opt<float64>` instantiates the None at float64.
@paradigm procedural

enum Opt<T> {
    Some(v: T),
    None,
}

func main() -> int32 {
    mut x: Opt<float64> = Opt.Some(1.5)
    x = Opt.None
    match x {
        Some(v) => println("some"),
        None => println("none"),
    }
    return 0
}
