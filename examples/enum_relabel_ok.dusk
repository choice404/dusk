// FIX-A accept twin: the same shape with a matching int64 payload constructs and
// reads back cleanly.
@paradigm procedural

enum Box<T> {
    Has(v: T),
    Empty,
}

func keep<T>(seed: T, b: Box<T>) -> Box<T> {
    return b
}

func main() -> int32 {
    b := keep(0, Box.Has(7))
    match b {
        Has(v) => println("has {}", v),
        Empty => println("empty"),
    }
    return 0
}
