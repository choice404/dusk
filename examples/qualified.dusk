@paradigm procedural

@import std.io
@import std.string

// Qualified call syntax: reach an imported function through its module path,
// std.io.print_line and std.string.str_len, instead of the bare name. The
// loader folds the path to the merged global.
func main() -> int32 {
    std.io.print_line("qualified")
    std.io.print_int(std.string.str_len("qualified"))
    return 0
}
