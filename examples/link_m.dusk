@paradigm procedural

// @link names a library to pass to the linker: a bare name like "m" becomes the
// -lm flag. sqrt is bound from libm and called across the C boundary; the result
// is compared as a value so the golden asserts on an integer, not a float format.
@link "m"

foreign "C" {
    func sqrt(x: float64) -> float64
}

func main() -> int64 {
    r: float64 = sqrt(16.0)
    if r == 4.0 {
        println(1)
    } else {
        println(0)
    }
    return 0
}
