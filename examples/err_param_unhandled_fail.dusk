// FIX-1: an error parameter carries the same must-handle obligation a let-bound
// error does. `swallow` receives e and drops it, so the hand-off at the call site
// would end the chain with no one accountable. The empty body is rejected: 'err'
// is never handled.
@paradigm procedural

func fail() -> (int64, error) {
    return (0, error { message: "boom" })
}

func swallow(err: error) -> void {
}

func main() -> int32 {
    v, e := fail()
    println(v)
    swallow(e)
    return 0
}
