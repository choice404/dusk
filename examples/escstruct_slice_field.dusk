// A struct returned by value with a slice field viewing a frame-local array.
// The struct copies out, but its slice field still points at mk's dead frame, so
// the return is rejected at the field.
@paradigm procedural
struct Batch { rows: int64[] }
func mk() -> Batch {
    a: int64[3] = [1, 2, 3]
    return Batch { rows: a[0..2] }
}
func main() -> int32 {
    b := mk()
    println(b.rows[0])
    return 0
}
