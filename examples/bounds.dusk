@paradigm procedural

// An out of bounds array index traps in the bounds check instead of reading
// past the end of the array. The check covers a negative index too, since an
// unsigned compare treats it as a large value.
func main() -> int32 {
    xs: int64[3] = [1, 2, 3]
    println(xs[0])
    println(xs[5])
    return 0
}
