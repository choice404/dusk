@paradigm procedural

// xs[0..=3] on a length 3 array becomes the exclusive form xs[0..4], which
// faults on the existing hi <= len bounds check.
func main() -> int32 {
    xs: int64[3] = [1, 2, 3]
    full: int64[] = xs[0..3]
    println(full.len)
    s: int64[] = xs[0..=3]
    println(s.len)
    return 0
}
