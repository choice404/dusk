@paradigm functional

monad Identity {
    func bind(x: int64, f: (int64) -> int64) -> int64 {
        return f(x)
    }

    func unit(x: int64) -> int64 {
        return x
    }
}

func main() -> int32 {
    r := do Identity {
        a <- 10
        b <- 20
        a + b
    }
    x: int64 = 5
    println(r)
    println(x)
    return 0
}
