// vec_fold accepts a capturing closure as its combiner, exactly as vec_map and
// vec_filter do. The first fold starts from a captured base and adds each element;
// the second captures a weight and folds a weighted sum, proving the closure's
// captured environment threads through the generic higher order call.
@paradigm procedural

@import std.vector

func main() -> int32 {
    nums: *Vector<int64> = alloc(vec_new())
    vec_push(nums, 1)
    vec_push(nums, 2)
    vec_push(nums, 3)

    base: int64 = 100
    total := vec_fold(nums, base, lambda (a: int64, x: int64) -> int64 { return a + x })
    println(total)

    weight: int64 = 10
    weighted := vec_fold(nums, 0, lambda (a: int64, x: int64) -> int64 { return a + x * weight })
    println(weighted)

    vec_free(nums)
    free(nums)
    return 0
}
