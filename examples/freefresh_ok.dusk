@paradigm procedural
@import std.vector

// A call that hands back a fresh pointer, aliasing no argument, is a clean owner: free
// stays legal for the alloc builtin and for any function whose summary reads no
// argument back through its result. Only a container read is refused.
func make() -> *int64 {
    return alloc(42)
}

func main() -> int32 {
    free(alloc(7))
    free(make())
    println(0)
    return 0
}
