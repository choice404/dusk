/** A small program that carries doc blocks and still builds and runs. Doc blocks
    evaporate at the lexer exactly like plain comments, so they cannot affect the
    emitted code. */
@paradigm procedural

/** Doubles its argument.
 *  @param n the value to double
 *  @return twice n
 */
func twice(n: int64) -> int64 {
    return n + n
}

/** The entry point. */
func main() -> int32 {
    println(twice(21))
    return 0
}
