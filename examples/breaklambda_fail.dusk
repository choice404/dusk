// A lambda is its own function boundary, so a break inside a lambda body is
// rejected even when the call sits inside an enclosing loop.
@paradigm procedural
@paradigm functional

func main() -> int32 {
    xs: int64[3] = [1, 2, 3]
    mut i: int64 = 0
    while i < 3 {
        foreach(xs, lambda (x: int64) -> void {
            break
        })
        i = i + 1
    }
    return 0
}
