@paradigm procedural

// The slice-behind-pointer shape: the collected element is a pointer to a slice
// that views a frame local array. The collected block outlives the frame, so the
// slice it points at dangles. The mint is refused, the same as the rejected
// `return p`.
func mk() -> collector<*int64[]> {
    a: int64[3] = [1, 2, 3]
    p: *int64[] = alloc(a[0..2])
    return collector<*int64[]>(p)
}

func main() -> int32 {
    c := mk()
    println((*(*c))[0])
    return 0
}
