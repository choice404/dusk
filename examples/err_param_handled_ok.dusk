// FIX-1 accept twin: the callee inspects its error parameter with exists, so the
// obligation is discharged in the callee body and the hand-off is accountable.
@paradigm procedural

func fail() -> (int64, error) {
    return (0, error { message: "boom" })
}

func handle(err: error) -> int64 {
    if err.exists() {
        return 1
    }
    return 0
}

func main() -> int32 {
    v, e := fail()
    println(v)
    println(handle(e))
    return 0
}
