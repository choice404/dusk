@paradigm procedural

// The compile-fail twin of elseif.dusk. An `else if` desugars to an ordinary
// nested `if`, so its condition is type-checked like any `if` condition: a
// non-bool `else if` condition is rejected at the condition, not silently
// coerced. The caret lands on the `3`.
func f(n: int64) -> void {
    if n == 1 {
        println("one")
    } else if 3 {
        println("three")
    }
}

func main() -> int64 {
    f(1)
    return 0
}
