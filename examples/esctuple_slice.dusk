// An escaping slice buried in a returned tuple. The array literal lives in mk's
// frame; wrapping it in a tuple does not launder the escape, so returning it is
// a use-after-return and is rejected.
@paradigm procedural
func mk() -> (int64[], int64) {
    return ([1, 2, 3], 42)
}
func main() -> int32 {
    s, n := mk()
    println(s[0])
    println(n)
    return 0
}
