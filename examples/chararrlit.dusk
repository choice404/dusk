// A string literal initializes a char array when its byte length matches
// exactly: the plain fit, the mut reassign, an element write after the copy,
// a multibyte UTF-8 literal counted in bytes, and a decoded escape.
@paradigm procedural

func main() -> int32 {
    s: char[5] = "Hello"
    println(s)
    mut m: char[3] = "abc"
    m = "xyz"
    println(m)
    m[0] = 'q'
    println(m)
    u: char[6] = "héllo"
    println(u)
    e: char[3] = "a\nb"
    println(e)
    return 0
}
