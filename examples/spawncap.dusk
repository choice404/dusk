// A spawned lambda cannot capture a slice, because a slice may view the
// spawning frame and the heap copied environment would dangle it. This
// program does not compile.
func main() -> int32 {
    xs: int64[3] = [1, 2, 3]
    s: int64[] = xs[0..3]
    t, e := spawn(lambda () -> void {
        println(s[0])
    })
    e.ignore()
    je := join(t)
    je.ignore()
    return 0
}
