// A range slice is validated against its base: lo <= hi <= len. A range past
// the end faults instead of fabricating a slice whose length launders out of
// bounds reads past the index check.
func main() -> int32 {
    xs: int64[3] = [1, 2, 3]
    s: int64[] = xs[0..2]
    println(s.len)
    t: int64[] = xs[0..10]
    println(t.len)
    return 0
}
