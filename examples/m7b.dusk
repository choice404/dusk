@paradigm procedural

enum Color {
    Red,
    Green,
    Blue,
    Custom(code: int64),
}

func code(c: Color) -> int64 {
    x := match c {
        Red => 1,
        Green => 2,
        Custom(n) => n,
        _ => 0,
    }
    return x
}

func main() -> int32 {
    println(code(Color.Red))
    println(code(Color.Green))
    println(code(Color.Blue))
    println(code(Color.Custom(99)))
    return 0
}
