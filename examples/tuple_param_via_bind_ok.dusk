// The no-over-reject proof: a param slice carried through a tuple BINDING and
// returned by name is legal, since the caller owns the backing. It must check,
// build, and run, unlike the frame-local-array forms it resembles.
@paradigm procedural
func pair(xs: int64[]) -> (int64[], int64) {
    t := (xs, 5)
    return t
}
func main() -> int32 {
    data: int64[3] = [10, 20, 30]
    s, n := pair(data[0..3])
    println(s[0])
    println(n)
    return 0
}
