// In-bounds string range slices through every base shape: a binding, a
// literal, and a call result, including the full and empty windows.
@paradigm procedural

func str_head() -> string {
    return "wxyz"
}

func main() -> int32 {
    s := "abcd"
    println(s[1..3])
    println(s[0..4])
    println("abcd"[1..3])
    println(str_head()[0..2])
    e: char[] = s[2..2]
    println(e.len)
    println(s[0..3][1..3])
    return 0
}
