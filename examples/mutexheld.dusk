// Freeing a mutex while holding it is fatal by name. The trylock probe in
// the runtime catches the live holder before the destroy can pull the lock
// out from under it.
@paradigm procedural
@import std.concurrent.sync

func main() -> int32 {
    m := mutex_new()
    println("locking")
    lock(m)
    mutex_free(m)
    println("unreached")
    return 0
}
