@paradigm procedural

// A string is a fat view, not a raw pointer, so it cannot ride a C vararg. The
// checker names the value and points at the fix: pass a *raw char instead.
foreign "C" {
    func cvararg(n: int64, ...) -> int64
}

func main() -> int64 {
    r: int64 = cvararg(1, "hello")
    println(r)
    return 0
}
