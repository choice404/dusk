// Re-slicing an unannotated array literal binding inside a tuple. a infers to a
// slice, so the type of a[0..2] hides the escape; the recorded escape flag on a
// catches it, and the tuple return is rejected.
@paradigm procedural
func mk() -> (int64[], int64) {
    a := [1, 2, 3]
    return (a[0..2], 5)
}
func main() -> int32 {
    s, n := mk()
    println(s[0])
    println(n)
    return 0
}
