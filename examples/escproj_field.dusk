// Projecting a slice field out of a local struct. s holds a slice into a local
// array; returning the field s.rows extracts the frame-local view, so it is
// rejected even though the whole struct is not returned.
@paradigm procedural
struct W { rows: int64[] }
func mk() -> int64[] {
    a: int64[3] = [1, 2, 3]
    s := W { rows: a[0..2] }
    return s.rows
}
func main() -> int32 {
    r := mk()
    println(r[0])
    return 0
}
