// A frame-local enum laundered through a binding. x holds an enum constructor
// whose payload views a local array; the escape flag propagates, so returning x
// is rejected.
@paradigm procedural
enum E { V(rows: int64[]), N }
func mk() -> E {
    a: int64[3] = [1, 2, 3]
    x := E.V(a[0..2])
    return x
}
func main() -> int32 {
    e := mk()
    match e {
        V(r) => { println(r[0]) }
        N => { println(0) }
    }
    return 0
}
