@paradigm procedural

// A float32 reaches the f64 runtime printer, so each sink widens the float to a
// double with an fpext first. Printed direct, printed after a float32 multiply,
// and printed through a format hole; all three must link and print the value.
func main() -> int32 {
    g: float32 = 3.5
    println(g)
    h: float32 = g * 2.0
    println(h)
    println("g = {}", g)
    return 0
}
