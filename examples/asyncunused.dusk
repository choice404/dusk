@paradigm procedural
@import std.async.future

// A bound future follows the ordinary unused variable rule; binding it and
// never awaiting or releasing it is still just an unused binding.
async func g() -> int64 {
    return 1
}

async func amain() -> int64 {
    fa := g()
    return 1
}

func main() -> int32 {
    r := async_run(amain())
    println(r)
    return 0
}
