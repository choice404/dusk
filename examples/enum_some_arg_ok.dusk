// FIX-B accept twin: a payload-carrying ctor pins T, so the call type-checks.
@paradigm procedural

enum Opt<T> {
    Some(v: T),
    None,
}

func take<T>(x: Opt<T>) -> int64 {
    match x {
        Some(v) => return 1,
        None => return 0,
    }
}

func main() -> int32 {
    println(take(Opt.Some(1)))
    return 0
}
