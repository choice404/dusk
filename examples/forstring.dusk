// A for loop iterates a string's bytes as chars, front to back, with the
// length scanned once at entry. The glyphs of a multibyte string survive byte
// wise printing, and the loop var widens to an int like any char.
@paradigm procedural

func main() -> int32 {
    s := "héllo"
    mut n: int64 = 0
    for c in s {
        print(c)
        n = n + 1
    }
    println("")
    println(n)
    for c2 in "ab" {
        b: int64 = c2
        println(b)
    }
    return 0
}
