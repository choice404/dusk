// implenum_fail: methods attach to structs only. An impl block naming an enum is
// rejected by name, pinning the ledger verdict that closed the impl-self item.
@paradigm oop

enum E {
    A,
    B,
}

impl E {
    func kind() -> int64 {
        return 0
    }
}

func main() -> int64 {
    return 0
}
