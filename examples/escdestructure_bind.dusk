// M5 intraprocedural twin: destructuring a tuple BINDING, not a literal, must
// still propagate the members' frame-view flags. t holds a frame-local slice in
// position 0, so `a, n := t` marks a escaping and returning it is rejected.
@paradigm procedural

func mk() -> int64[] {
    local: int64[4] = [111, 222, 333, 444]
    t := (local[0..4], 5)
    a, n := t
    println(n)
    return a
}

func main() -> int32 {
    v := mk()
    println(v[0])
    return 0
}
