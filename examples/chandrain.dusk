// The value beside a drained receive's error is the zero pattern for the
// element and means nothing. For a managed pointer that zero is null, and
// dereferencing it faults by name through the untracked pointer's null check
// rather than dying by raw signal.
@paradigm procedural
@import std.concurrent.channel

func main() -> int32 {
    c: Channel<*int64> = chan_new(1)
    chan_close(c)
    q, e := chan_recv(c)
    println(e.exists())
    println(*q)
    chan_free(c)
    return 0
}
