@paradigm procedural

// `collector` is a contextual name, not a reserved word: only `collector<T>(...)`
// mints, so the name stays an ordinary identifier everywhere else, including as
// the left side of a comparison where `collector <` could look like a mint.
func main() -> int32 {
    collector := 3
    n := 5
    if collector < n {
        println(1)
    } else {
        println(0)
    }
    return 0
}
