@paradigm procedural
@paradigm oop

struct Point {
    x: int64,
    y: int64,
}

impl Point {
    func sum() -> int64 {
        return self.x + self.y
    }
}

func main() -> int32 {
    p := Point { x: 3, y: 4 }
    println(p.sum())
    println(p.x)

    q: *int64 = alloc(100)
    defer free(q)
    println(*q)

    return 0
}
