@paradigm procedural
@import std.vector

// vec_take is bounds checked exactly as vec_get: an index at or past the length
// faults by name instead of reading past the buffer.
func main() -> int32 {
    v: *Vector<int64> = alloc(vec_new())
    vec_push(v, 10)
    vec_push(v, 20)
    println(vec_len(v))
    x: int64 = vec_take(v, 5)
    println(x)
    vec_free(v)
    free(v)
    return 0
}
