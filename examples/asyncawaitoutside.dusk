@paradigm procedural
@import std.async.future

// 'await' only suspends inside an async func. A sync func has no task frame to
// park, so the keyword is rejected at the parse where it appears, even though
// f is a legally minted future.
func main() -> int32 {
    f: Future<int64> = future_new()
    v, e := await f
    e.ignore()
    println(v)
    return 0
}
