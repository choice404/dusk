@paradigm procedural

// Exponent: right associative, unary minus binds tighter than **, 0 ** 0 is 1,
// a negative base, a dynamic (non constant) exponent, and the float path.
func main() -> int32 {
    println(2 ** 10)
    println(2 ** 3 ** 2)
    println(-2 ** 2)
    println(0 ** 0)
    println(-3 ** 3)
    n: int64 = 5
    println(2 ** n)
    println(2.0 ** 10.0)
    println(2.5 ** 2.0)
    return 0
}
