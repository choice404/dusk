@paradigm procedural

// All ten compound assignment forms, chained on one mutable int and one
// mutable float so each rewrites the same place through a load, the op, and a
// single store.
func main() -> int32 {
    mut x: int64 = 10
    x += 5
    x -= 3
    x *= 2
    x /= 4
    x %= 4
    x &= 3
    x |= 5
    x ^= 1
    x <<= 2
    x >>= 3
    println(x)

    mut y: float64 = 2.0
    y += 1.0
    y -= 0.5
    y *= 4.0
    y /= 5.0
    y %= 1.5
    println(y)
    return 0
}
