// Spec audit: an impl block declares object methods, so it requires the oop
// paradigm just as an interface does. A file that declares only procedural is
// rejected until it opts into oop.
@paradigm procedural

struct Point { x: int64, y: int64 }

impl Point {
    func sum() -> int64 { return self.x + self.y }
}

func main() -> int32 {
    return 0
}
