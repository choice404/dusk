// A frame-local array of slices laundered through a binding. s holds an array
// literal whose elements slice a local array; the escape flag propagates, so
// returning s is rejected.
@paradigm procedural
func mk() -> int64[][2] {
    a: int64[3] = [1, 2, 3]
    s := [a[0..2], a[0..1]]
    return s
}
func main() -> int32 {
    g := mk()
    println(g[0][0])
    return 0
}
