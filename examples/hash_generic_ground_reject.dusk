@paradigm procedural

// A generic function may call hash on its parameter; the surface pass admits it,
// and the ground pass rejects an instantiation whose key type is not hashable.
struct Box { v: int64 }

func key_of<K>(k: K) -> int64 {
    return hash(k)
}

func main() -> int32 {
    b: Box = Box { v: 1 }
    return int32(key_of(b))
}
