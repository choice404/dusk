@paradigm procedural

// A slice field is barred from a boundary struct. A slice is a fat {ptr, len}
// value with no C counterpart, so a struct that carries one cannot cross by
// value; pass the backing as a raw pointer and a length instead.
struct Bad { data: int64[], n: int64 }

foreign "C" {
    func f(b: Bad) -> int64
}

func main() -> int64 {
    return 0
}
