// An enum returned by value with a slice payload viewing a frame-local array.
// The enum copies out, but its payload slice still points at mk's dead frame, so
// the return is rejected at the payload.
@paradigm procedural
enum E { V(rows: int64[]), N }
func mk() -> E {
    a: int64[3] = [1, 2, 3]
    return E.V(a[0..2])
}
func main() -> int32 {
    e := mk()
    match e {
        V(r) => { println(r[0]) }
        N => { println(0) }
    }
    return 0
}
