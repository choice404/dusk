// The no-over-reject: a fixed array whose slice elements come from params, the
// caller owns their backing, so returning the array by value is legal. Must
// build and run.
@paradigm procedural
func mk(xs: int64[], ys: int64[]) -> int64[][2] {
    return [xs, ys]
}
func main() -> int32 {
    d: int64[3] = [10, 20, 30]
    e: int64[3] = [40, 50, 60]
    g := mk(d[0..3], e[0..3])
    println(g[0][0])
    return 0
}
