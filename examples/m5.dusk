@paradigm procedural

func add(a: int64, b: int64) -> int64 {
    return a + b
}

func fib(n: int64) -> int64 {
    if n < 2 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

func main() -> int32 {
    x := add(20, 22)
    println(x)
    println(fib(10))

    mut i: int64 = 0
    mut sum: int64 = 0
    while i < 5 {
        sum = sum + i
        i = i + 1
    }
    println(sum)
    return 0
}
