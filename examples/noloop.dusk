// Every future lives on the loop, so minting one before loop_init faults by
// name, the forgot to initialize story told directly instead of through a
// crash somewhere later.
@paradigm procedural
@import std.async.future

func main() -> int32 {
    f: Future<int64> = future_new()
    v, e := await(f)
    e.ignore()
    println(v)
    println("unreached")
    return 0
}
