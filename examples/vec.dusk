@paradigm procedural
@import std.vector
func main() -> int32 {
  v: *Vector<int64> = alloc(vec_new())
  mut i: int64 = 0
  while i < 6 {
    vec_push(v, i * 10)
    i = i + 1
  }
  println(vec_len(v))
  mut j: int64 = 0
  while j < vec_len(v) {
    println(vec_get(v, j))
    j = j + 1
  }
  vec_free(v)
  free(v)
  return 0
}
