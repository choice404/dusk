// A struct with a Display impl prints through its toString; print and println
// both route it to the string printers.
@paradigm oop
@paradigm procedural

interface Display {
    toString() -> string
}

struct Point {
    x: int64,
    y: int64,
}

impl Display for Point {
    func toString() -> string {
        return "point"
    }
}

func main() -> int32 {
    p := Point { x: 1, y: 2 }
    println(p)
    print(p)
    println("")
    return 0
}
