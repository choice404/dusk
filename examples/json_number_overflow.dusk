@paradigm procedural

// A grammatically valid number whose magnitude overflows float64 is refused, not
// parsed to an infinity that would emit as "inf", which is not JSON and would not
// reparse. This keeps the accepted set inside real, round-trippable JSON.
@import std.io
@import std.json

func main() -> int32 {
    j, pe := json_parse("1e400")
    if pe.exists() {
        println(pe.message)
        return 0
    }
    println(json_emit(j))
    return 0
}
