@paradigm procedural

// A stale free. After p is freed its block is reused by q, so p now holds a
// stale generation. Freeing p a second time must fault at the free, before it
// can free q's live allocation out from under it.
func main() -> int32 {
    p: *int64 = alloc(1)
    free(p)
    q: *int64 = alloc(2)
    println(*q)
    free(p)
    println(99)
    return 0
}
