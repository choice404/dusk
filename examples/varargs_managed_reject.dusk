@paradigm procedural

// A managed *T carries a generation header C cannot read, so it cannot cross a C
// vararg. The checker refuses it and points at *raw T or *void.
foreign "C" {
    func cvararg(n: int64, ...) -> int64
}

func main() -> int64 {
    p: *int64 = alloc(7)
    r: int64 = cvararg(1, p)
    free(p)
    println(r)
    return 0
}
