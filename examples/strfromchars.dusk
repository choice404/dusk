// str_from_chars copies a char slice into a fresh heap string, the bridge
// from stack text back to the dynamic string world.
@paradigm procedural

@import std.string

func main() -> int32 {
    a: char[5] = "Hello"
    s: string = str_from_chars(a[0..5])
    println(s)
    println(str_len(s))
    t: string = str_from_chars(a[1..4])
    u: *StringBuilder = concat(t, "!")
    println(sb_cstr(u))
    sb_free(u)
    free(u)
    free(s)
    free(t)
    return 0
}
