// Spec audit: a monad is the (unit, bind) pair, and a `do` block desugars to
// calls of both. A monad block that defines only one of them is rejected at the
// block, since the missing operation would resolve to nothing at the desugar.
@paradigm functional

struct Box<T> { v: T }

monad Box {
    export func unit<A>(x: A) -> Box<A> {
        return Box { v: x }
    }
}

func main() -> int32 {
    return 0
}
