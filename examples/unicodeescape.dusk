@paradigm procedural

// Unicode \u{...} escapes decode to their scalar and print as UTF-8. One or two
// digit code points, a pair of CJK characters, and an astral emoji all round
// trip through a single string literal.
func main() -> int32 {
    println("\u{48}\u{69} \u{4E2D}\u{6587} \u{1F600}")
    return 0
}
