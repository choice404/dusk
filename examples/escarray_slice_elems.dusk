// A fixed array returned by value whose slice elements view a frame-local array.
// The array copies out, but each element still points at mk's dead frame, so the
// return is rejected at the fat element.
@paradigm procedural
func mk() -> int64[][2] {
    a: int64[3] = [1, 2, 3]
    return [a[0..2], a[0..1]]
}
func main() -> int32 {
    g := mk()
    println(g[0][0])
    return 0
}
