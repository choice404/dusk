// The no-over-reject for covariance: a slice-of-interface value passed where a
// slice-of-interface is expected is not a reinterpretation. Must build and run.
@paradigm oop
@paradigm procedural
interface Sized { size() -> int64 }
struct Box { v: int64 }
impl Sized for Box { func size() -> int64 { return self.v } }
func take(ys: Sized[]) -> int64 { return ys[0].size() }
func main() -> int32 {
    xs: Sized[] = [Box { v: 42 }]
    println(take(xs))
    return 0
}
