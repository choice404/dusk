// A pointer comparison would compare addresses, not the values pointed to,
// so it is rejected outright rather than silently doing the wrong thing.
@paradigm procedural

func main() -> int32 {
    x: int64 = 5
    p: *int64 = alloc(x)
    q: *int64 = alloc(x)
    if p == q {
        println("bad")
    }
    free(p)
    free(q)
    return 0
}
