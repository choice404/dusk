@paradigm procedural

func head3(xs: int64[]) -> int64 {
    return xs[0] + xs[1] + xs[2]
}

func main() -> int32 {
    xs: int64[5] = [1, 2, 3, 4, 5]

    s: int64[] = xs[0..5]
    println(head3(s))

    inner: int64[] = s[1..4]
    println(inner.len)
    println(inner[0])
    println(inner[2])

    mut p: *int64 = alloc(7)
    defer free(p)
    p[0] = 42
    println(p[0])

    return 0
}
