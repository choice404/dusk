// vec_get is bounds checked: an index past the length faults instead of
// reading past the buffer.
@paradigm procedural
@import std.vector

func main() -> int32 {
    v: *Vector<int64> = alloc(vec_new())
    vec_push(v, 10)
    vec_push(v, 20)
    println(vec_get(v, 1))
    println(vec_get(v, 9))
    return 0
}
