@paradigm procedural

// A struct is not a hashable key, so a map keyed by one is rejected once the
// key type is ground.
@import std.string
@import std.map

struct Point { x: int64, y: int64 }

func main() -> int32 {
    m: *Map<Point, int64> = alloc(map_new())
    map_put(m, Point { x: 1, y: 2 }, 7)
    return 0
}
