@paradigm procedural

struct Point {
    x: int64,
    y: int64,
}

// A collected value is reclaimed by the collector, never freed. The accept twin
// is a copy that reads the value directly, as in collectorbox.dusk, and any
// owned `*T` still frees normally, as in m6.dusk.
func main() -> int32 {
    c := collector<Point>(Point { x: 1, y: 2 })
    free(c)
    return 0
}
