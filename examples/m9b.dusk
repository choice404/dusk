@paradigm functional

func bind(x: int64, f: (int64) -> int64) -> int64 {
    return f(x)
}

func unit(x: int64) -> int64 {
    return x
}

func main() -> int32 {
    nums: int64[] = [10, 20, 30]
    foreach(
        map(nums, lambda (n: int64) -> int64 { return n + 1 }),
        lambda (n: int64) -> void { println(n) }
    )

    r := do {
        a <- 7
        99
        b <- 3
        a * b
    }
    println(r)

    return 0
}
