// Spec audit: a literal enum-constructor payload ranges against the variant's
// declared width, so a value too wide to fit int32 is rejected at the
// constructor rather than silently truncating to a wrong value in codegen.
@paradigm procedural

enum E {
    Has(v: int32),
    Nope,
}

func main() -> int32 {
    e := E.Has(4294967297)
    match e {
        Has(v) => println(v),
        Nope   => println(0),
    }
    return 0
}
