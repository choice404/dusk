@paradigm procedural

// A bool field is barred from a boundary struct. A bool lowers to an i1, which
// has no settled one-byte storage rule at the C boundary, so a field must use
// char or int8 to carry a truth value across.
struct Bad { flag: bool, y: int64 }

foreign "C" {
    func f(b: Bad) -> int64
}

func main() -> int64 {
    return 0
}
