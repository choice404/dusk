// The no-over-reject: an enum whose slice payload comes from a param, the caller
// owns the backing, so it does not view mk's frame. Must build and run.
@paradigm procedural
enum E { V(rows: int64[]), N }
func mk(xs: int64[]) -> E {
    return E.V(xs)
}
func main() -> int32 {
    d: int64[3] = [10, 20, 30]
    e := mk(d[0..3])
    match e {
        V(r) => { println(r[0]) }
        N => { println(0) }
    }
    return 0
}
