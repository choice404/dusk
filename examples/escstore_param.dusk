// Compile-fail: a direct store of a frame view into a parameter place. The
// slice slot dst[0] belongs to the caller, so the view of fill's local array
// outlives fill's frame no matter what the caller does with it.
@paradigm procedural

func fill(dst: int64[][]) -> void {
    local: int64[4] = [111, 222, 333, 444]
    dst[0] = local[0..4]
}

func main() -> int32 {
    seed: int64[1] = [7]
    mut rows: int64[][1] = [seed[0..1]]
    fill(rows[0..1])
    println(rows[0][0])
    return 0
}
