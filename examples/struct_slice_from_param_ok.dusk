// A struct holding a slice field from a param, the caller owns the backing, so
// it does not view mk's frame. A struct with a fat field is a common legal shape
// and must build and run.
@paradigm procedural
struct Batch { rows: int64[] }
func mk(xs: int64[]) -> Batch {
    return Batch { rows: xs }
}
func main() -> int32 {
    d: int64[3] = [10, 20, 30]
    b := mk(d[0..3])
    println(b.rows[0])
    return 0
}
