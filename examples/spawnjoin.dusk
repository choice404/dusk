// spawn runs a lambda on a new OS thread and returns a (thread, error) pair.
// join blocks until the body returns, so the worker's line always prints
// before main's.
func main() -> int32 {
    t, e := spawn(lambda () -> void {
        println("worker")
    })
    if e.exists() {
        printerr(e)
        return 1
    }
    je := join(t)
    je.ignore()
    println("done")
    return 0
}
