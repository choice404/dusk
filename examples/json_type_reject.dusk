// Compile-fail twin for std.json: the Json.JNum constructor takes a float64
// payload, so handing it a string is a type error the checker rejects before
// any code runs. The accept path lives in json_roundtrip.dusk and the other
// json examples, which build every variant with its declared payload type.
@paradigm procedural

@import std.json

func main() -> int32 {
    bad: *Json = alloc(Json.JNum("not a number"))
    println(json_emit(bad))
    return 0
}
