// FIX-3: a non-generic call threads the declared parameter type as the argument's
// expected, so `show(Opt.None)` instantiates the None at the parameter's element.
@paradigm procedural

enum Opt<T> {
    Some(v: T),
    None,
}

func show(o: Opt<float64>) -> void {
    match o {
        Some(v) => println("some"),
        None => println("none"),
    }
}

func main() -> int32 {
    show(Opt.None)
    return 0
}
