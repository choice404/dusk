// Returning an interface value by value is not supported: codegen boxes the
// payload into a frame slot that dangles on return, so it is rejected.
@paradigm oop
@paradigm procedural
interface View { first() -> int64 }
struct Holder { rows: int64[] }
impl View for Holder {
    func first() -> int64 { return self.rows[0] }
}
func mk() -> View {
    a: int64[3] = [1, 2, 3]
    return Holder { rows: a[0..2] }
}
func main() -> int32 {
    v := mk()
    println(v.first())
    return 0
}
