@paradigm procedural
@paradigm oop

// owning marks a top level func, not a method. The blessing keys on a bare identifier
// callee, so a method could never bless anyway; the impl parser rejects it directly.
struct T {
    x: int64,
}

impl T {
    owning func take() -> *int64 {
        return alloc(1)
    }
}

func main() -> int32 {
    return 0
}
