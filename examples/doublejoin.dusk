// The thread handle is a generational record and join retires it, so a second
// join faults through the same check a use after free hits.
func main() -> int32 {
    t, e := spawn(lambda () -> void {
        println("once")
    })
    e.ignore()
    j1 := join(t)
    j1.ignore()
    j2 := join(t)
    j2.ignore()
    println("unreachable")
    return 0
}
