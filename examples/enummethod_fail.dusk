// Spec audit: methods are not supported on an enum, so a method call on an enum
// value has no dispatch. It is rejected by name instead of falling through to a
// permissive Unknown that codegen lowers to a wrong zero.
@paradigm procedural

enum Maybe {
    Just(v: int64),
    Nothing,
}

func main() -> int32 {
    m := Maybe.Just(5)
    println(m.unwrap())
    return 0
}
