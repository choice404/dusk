// selfptr_fail: self is the receiver value, not a pointer to it, so returning
// self where a pointer type is expected is rejected. The guard is what makes a
// method's receiver unable to leak as an alias the checker cannot see.
@paradigm oop

struct C {
    v: int64
}

impl C {
    func leak() -> *C {
        return self
    }
}

func main() -> int64 {
    return 0
}
