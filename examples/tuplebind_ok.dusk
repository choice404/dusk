// Accept twin of tuplebind_fail: destructuring the fallible result binds the
// error to its own name, so the must-handle obligation is discharged with
// ignore and the program is accepted.
@paradigm procedural

func fail() -> (int64, error) {
    return (7, error { message: "boom" })
}

func main() -> int32 {
    v, e := fail()
    e.ignore()
    println(v)
    return 0
}
