// The no-over-reject for slice-index projection: indexing a param slice of slices
// yields a caller-owned inner slice, legal to return. Must build and run.
@paradigm procedural
func mk(g: (int64[])[]) -> int64[] {
    return g[0]
}
func main() -> int32 {
    a: int64[3] = [10, 20, 30]
    grid: (int64[])[] = [a[0..3]]
    r := mk(grid)
    println(r[0])
    return 0
}
