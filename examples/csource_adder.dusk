@paradigm procedural

// @csource names a C source, resolved against this file's directory, that the
// driver compiles and links alongside the runtime. The foreign block binds add
// against the definition in csource_adder.c.
@csource "csource_adder.c"

foreign "C" {
    func add(a: int64, b: int64) -> int64
}

func main() -> int64 {
    println(add(2, 3))
    return 0
}
