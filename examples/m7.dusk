@paradigm procedural

enum Shape {
    Circle(radius: int64),
    Rect(w: int64, h: int64),
    Empty,
}

func area(s: Shape) -> int64 {
    match s {
        Circle(r)  => return r * r * 3,
        Rect(w, h) => return w * h,
        Empty      => return 0,
    }
}

func main() -> int32 {
    c := Shape.Circle(5)
    r := Shape.Rect(4, 6)
    e := Shape.Empty

    println(area(c))
    println(area(r))
    println(area(e))

    return 0
}
