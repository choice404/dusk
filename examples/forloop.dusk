@paradigm procedural

// A for loop over a fixed array, binding each element in turn. The loop lowers
// to an index counter walking the array's backing storage.
func main() -> int32 {
    xs: int64[3] = [1, 2, 3]
    mut sum: int64 = 0
    for x in xs {
        sum = sum + x
    }
    println(sum)
    return 0
}
