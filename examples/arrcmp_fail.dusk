// An array has no whole-value comparison; == on two arrays is rejected so a
// caller compares elements instead of getting an address or aggregate compare.
@paradigm procedural

func main() -> int32 {
    a: int64[2] = [1, 2]
    b: int64[2] = [1, 2]
    if a == b {
        println("bad")
    }
    return 0
}
