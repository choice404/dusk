@paradigm procedural
@import std.vector

// vec_get reads an element the container still holds, so freeing the read result
// would double free a live element. The checker refuses it and names the fix.
func main() -> int32 {
    v: *Vector<*int64> = alloc(vec_new())
    vec_push(v, alloc(10))
    free(vec_get(v, 0))
    vec_free(v)
    free(v)
    return 0
}
