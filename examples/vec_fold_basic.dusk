// std.vector's vec_fold reduces a vector to a single value, folding a closure
// left to right over the elements in index order from an initial accumulator.
// Here it sums a vector of integers, then joins a vector of strings, proving the
// accumulator type is independent of the element type: the same fold shape both
// stays an int64 and crosses from string elements into one joined string.
@paradigm procedural

@import std.vector
@import std.string

func main() -> int32 {
    nums: *Vector<int64> = alloc(vec_new())
    vec_push(nums, 1)
    vec_push(nums, 2)
    vec_push(nums, 3)
    vec_push(nums, 4)
    sum := vec_fold(nums, 0, lambda (a: int64, x: int64) -> int64 { return a + x })
    println(sum)

    words: *Vector<string> = alloc(vec_new())
    vec_push(words, "a")
    vec_push(words, "b")
    vec_push(words, "c")
    joined := vec_fold(words, "", lambda (a: string, x: string) -> string { return a + x })
    println(joined)

    vec_free(nums)
    free(nums)
    vec_free(words)
    free(words)
    return 0
}
