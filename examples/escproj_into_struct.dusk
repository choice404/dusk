// A projection placed into a struct field. s holds a local slice; extracting
// s.rows into a new struct still carries the frame-local view out.
@paradigm procedural
struct Inner { rows: int64[] }
struct Outer { rows: int64[] }
func mk() -> Outer {
    a: int64[3] = [1, 2, 3]
    s := Inner { rows: a[0..2] }
    return Outer { rows: s.rows }
}
func main() -> int32 {
    o := mk()
    println(o.rows[0])
    return 0
}
