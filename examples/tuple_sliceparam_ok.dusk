// A tuple carrying a slice that does NOT escape: the slice comes from a
// parameter, whose backing the caller owns, so returning it in a tuple is legal
// and must check clean. The proof the escape recursion does not over-reject.
@paradigm procedural
func f(xs: int64[]) -> (int64[], int64) {
    return (xs, 5)
}
func main() -> int32 {
    data: int64[3] = [1, 2, 3]
    s, n := f(data[0..3])
    println(s[0])
    println(n)
    return 0
}
