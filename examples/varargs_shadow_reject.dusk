// A local closure shadowing a variadic foreign name is an ordinary closure
// call, so the closure's own arity rule applies; the variadic leniency of the
// foreign printf must not ride through the shadow.
@paradigm functional

foreign "C" {
    func printf(fmt: *raw char, ...) -> int32
}

func main() -> int32 {
    printf := lambda (x: int64) -> int64 { return x + 1 }
    r: int64 = printf(1, 2, 3)
    println(r)
    return 0
}
