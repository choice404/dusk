// Unlocking a mutex this thread does not hold is fatal by name. The default
// pthread flavor leaves it undefined; the error checking kind reports it and
// the runtime turns the report into the named fault every other misuse gets.
@paradigm procedural
@import std.concurrent.sync

func main() -> int32 {
    m := mutex_new()
    println("unlocking")
    unlock(m)
    println("unreached")
    return 0
}
