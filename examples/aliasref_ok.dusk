@paradigm procedural
@paradigm functional
// The no-over-reject: a `ref` alias with a store of a scalar, not a frame view,
// through it. `ref q := c` links `q` to `c`, but `(*q).n = 5` raises no escape
// flag, so `c` stays clean and returning it is legal.
struct Cell { n: int64 }
func mk() -> *Cell {
    c: *Cell = alloc(Cell { n: 0 })
    ref q := c
    (*q).n = 5
    return c
}
func main() -> int32 {
    c := mk()
    println((*c).n)
    free(c)
    return 0
}
