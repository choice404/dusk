// vec_sort takes exactly two arguments, the vector pointer and the ordering
// closure; a stray third argument is an arity mismatch, not a silently
// ignored extra, the same rule every dusk function call enforces.
@paradigm procedural

@import std.vector

func cmp_i32(a: int32, b: int32) -> int32 {
    return a - b
}

func main() -> int32 {
    v: *Vector<int32> = alloc(vec_new())
    vec_push(v, 1)
    vec_sort(v, cmp_i32, 5)
    return 0
}
