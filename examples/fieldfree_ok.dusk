@paradigm procedural

struct Node {
    left: *int64,
    right: *int64,
}

// A field-chain free stays legal: freeing a managed field read through a pointer is an
// owner free the container-read rule never touches, since that rule fires only on a
// call result. This is the shape of map_free's own field releases.
func main() -> int32 {
    n: *Node = alloc(Node { left: alloc(1), right: alloc(2) })
    free((*n).left)
    free((*n).right)
    free(n)
    println(0)
    return 0
}
