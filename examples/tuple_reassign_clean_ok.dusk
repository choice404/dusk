// The no-over-reject proof for reassignment: a mut tuple binding that starts
// escaping is reassigned to a param slice, so the stale escape flag is cleared
// and the return is legal. Must build and run.
@paradigm procedural
func mk(xs: int64[]) -> (int64[], int64) {
    mut t := ([1, 2, 3], 5)
    t = (xs, 9)
    return t
}
func main() -> int32 {
    data: int64[3] = [10, 20, 30]
    s, n := mk(data[0..3])
    println(s[0])
    println(n)
    return 0
}
