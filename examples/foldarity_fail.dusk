// Spec audit: the functional builtins take a fixed number of arguments. Codegen
// reads only those operands, so a surplus argument would lower to invalid IR;
// the arity is ranged at the call and a miscount is a diagnostic.
@paradigm procedural
@paradigm functional

func main() -> int32 {
    xs: int64[3] = [1, 2, 3]
    r := fold(xs[0..3], 0, lambda (acc: int64, x: int64) -> int64 { return acc + x }, 99)
    println(r)
    return 0
}
