@paradigm procedural
@import std.async.future

// A defer runs at completion and cannot suspend, so an await under defer is
// rejected even though f is a legally minted future.
async func amain() -> int64 {
    f: Future<int64> = future_new()
    defer await f
    return 1
}

func main() -> int32 {
    r := async_run(amain())
    println(r)
    return 0
}
