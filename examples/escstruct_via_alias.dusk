// A frame-local struct laundered through a binding then an alias. s holds a
// slice into a local array; t aliases s; the escape flag propagates through both,
// so returning t is rejected.
@paradigm procedural
struct Batch { rows: int64[] }
func mk() -> Batch {
    a: int64[3] = [1, 2, 3]
    s := Batch { rows: a[0..2] }
    t := s
    return t
}
func main() -> int32 {
    b := mk()
    println(b.rows[0])
    return 0
}
