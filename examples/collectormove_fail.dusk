@paradigm procedural

struct Point {
    x: int64,
    y: int64,
}

// A collected value is not owned, so there is nothing to move. The accept twin
// is a plain copy, `d := c`, as in collectorbox.dusk.
func main() -> int32 {
    c := collector<Point>(Point { x: 1, y: 2 })
    d := move(c)
    println((*d).x)
    return 0
}
