@paradigm procedural

// Pipe rewrites x |> f(a) into f(x, a), left associative, and is the loosest
// operator, so it grabs the whole left hand expression before piping.
func double(n: int64) -> int64 {
    return n * 2
}

func plus(n: int64, m: int64) -> int64 {
    return n + m
}

func main() -> int32 {
    println(5 |> double)
    println(5 |> double |> plus(3))
    println(1 + 2 |> double)
    return 0
}
