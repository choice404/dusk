// An escaping slice tuple returned by a bare name, not a literal. t binds a
// tuple whose first member views a frame-local array; returning t propagates the
// dangling view, so it is rejected the same as returning the literal.
@paradigm procedural
func mk() -> (int64[], int64) {
    t := ([1, 2, 3], 42)
    return t
}
func main() -> int32 {
    s, n := mk()
    println(s[0])
    println(n)
    return 0
}
