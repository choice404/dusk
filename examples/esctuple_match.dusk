// An escaping slice tuple built by a match expression. Each arm materializes an
// array literal on this frame, so the match result carries a frame-local slice;
// returning it escapes and is rejected through the arm tails.
@paradigm procedural
enum Sel { A, B }
func mk(s: Sel) -> (int64[], int64) {
    return match s {
        A => ([1, 2, 3], 42),
        B => ([4, 5, 6], 7),
    }
}
func main() -> int32 {
    inner, k := mk(Sel.A)
    println(inner[0])
    println(k)
    return 0
}
