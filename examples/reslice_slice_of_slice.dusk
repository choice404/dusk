// A slice-of-a-slice laundered through a binding then a tuple. b re-slices a
// frame-local array literal binding, so b inherits the escape flag, and the
// tuple t holding b is rejected on return.
@paradigm procedural
func mk() -> (int64[], int64) {
    a := [1, 2, 3]
    b := a[0..2]
    t := (b, 5)
    return t
}
func main() -> int32 {
    s, n := mk()
    println(s[0])
    println(n)
    return 0
}
