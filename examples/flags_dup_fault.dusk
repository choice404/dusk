// Registering the same flag name twice is a program bug, not user input, so
// std.flags faults and aborts rather than silently overwriting the first spec.
@paradigm procedural

@import std.flags

func main() -> int32 {
    f: *Flags = alloc(flags_new("greet", "a greeting demo"))
    flag_bool(f, "verbose", "print more")
    flag_int(f, "verbose", 0, "a second registration of the same name")
    println("unreachable")
    return 0
}
