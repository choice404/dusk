// A width cast like int32(v) converts an integer explicitly: two's complement
// truncation narrowing down, sign extension widening up.
@paradigm procedural

func main() -> int32 {
    println(int32(300))
    println(int8(300))
    c := char(101)
    println(c)
    println(int64(c))
    n: int16 = int16(-1)
    println(n)
    x: int8 = -5
    println(int64(x))
    return 0
}
