@paradigm procedural

// The bitwise family on integers: & | ^ single character, ~ unary. Sign bits
// flow through two's complement the way C's do, and an int8 width keeps the
// mask honest at the narrow end.
func main() -> int32 {
    println(12 & 10)
    println(12 | 10)
    println(12 ^ 10)
    println(~12)
    println(-1 & 255)
    println(~0)
    a: int8 = -16
    b: int8 = 60
    println(a & b)
    return 0
}
