// W5: free validated at ground. A generic value of type T carries no proof of being a
// heap pointer at the surface, so free(x) checks clean there; once mono grounds T to
// int64 the ground type pass sees free applied to a scalar, which would emit a
// cool_gen_free on an i64 and die in clang. The ground pass refuses it by type.
@paradigm procedural

func release<T>(x: T) -> void {
    free(x)
}

func main() -> int32 {
    release(5)
    return 0
}
