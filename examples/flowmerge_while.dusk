// A reassignment to an escaping value inside a while body. The loop may or may
// not run, so the may-join treats a loop-body reassign as a possible escape; s
// stays flagged past the loop and the return is rejected.
@paradigm procedural
func mk(xs: int64[]) -> int64[] {
    mut s := xs
    mut i := 0
    while i < 1 {
        s = [1, 2, 3]
        i = i + 1
    }
    return s
}
func main() -> int32 {
    data: int64[3] = [10, 20, 30]
    r := mk(data[0..3])
    println(r[0])
    return 0
}
