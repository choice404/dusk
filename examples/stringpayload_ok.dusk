@paradigm procedural
@import std.string

// Freeing a heap string stays legal before and after the container-read rule: a string
// is not a managed pointer, so the rule never touches a string payload free, the shape
// json's JStr(s) => free(s) leans on.
func main() -> int32 {
    b: *StringBuilder = alloc(sb_new())
    sb_push(b, "hello")
    s: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    free(s)
    println(0)
    return 0
}
