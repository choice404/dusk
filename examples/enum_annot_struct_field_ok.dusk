// FIX-3: a struct-literal field threads the struct's grounded field type as its
// value's expected, so `Pair { v: Opt.None }` at `Pair<float64>` instantiates the
// None at float64 instead of defaulting and dying at clang.
@paradigm procedural

enum Opt<T> {
    Some(v: T),
    None,
}

struct Pair<T> {
    v: Opt<T>,
}

func main() -> int32 {
    x: Pair<float64> = Pair { v: Opt.None }
    match x.v {
        Some(v) => println("some"),
        None => println("none"),
    }
    return 0
}
