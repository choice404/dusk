@paradigm procedural

// main may take argc and the argv string slice. The compiler emits a C ABI
// entry wrapper that receives the real (int, char**) and builds the dusk slice,
// so argv.len matches argc instead of reading a garbage word. Run with no extra
// arguments, argv holds just the program name, so the length is one.
func main(argc: int32, argv: string[]) -> int32 {
    println(argv.len)
    return 0
}
