// privmonad_lib's monad W exports its struct but keeps bind and unit private,
// so a `do W { ... }` block here must reach the private, renamed pair, not the
// real one: a loud undefined name, not a silent wrong bind. This program does
// not compile.
@import privmonad_lib

@paradigm functional

func main() -> int32 {
    r := do W {
        a <- W { v: 3 }
        a + 1
    }
    println(r.v)
    return 0
}
