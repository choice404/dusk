// Indexing a slice-typed field of a local struct whose field views a frame-local
// array. The inner slice element views a dead frame; the projection roots through
// the slice index to the local binding, so it is caught.
@paradigm procedural
struct Grid { rows: (int64[])[] }
func mk() -> int64[] {
    inner: int64[3] = [111, 222, 333]
    g := Grid { rows: [inner[0..2]] }
    return g.rows[0]
}
func main() -> int32 {
    r := mk()
    println(r[0])
    return 0
}
