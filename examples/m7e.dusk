@paradigm procedural

enum List<T> {
    Cons(head: T, tail: *List<T>),
    Nil,
}

func main() -> int32 {
    tail: *List<int64> = alloc(List.Nil)
    defer free(tail)
    node: List<int64> = List.Cons(7, tail)
    match node {
        Cons(h, t) => println(h),
        Nil => println(0),
    }
    return 0
}
