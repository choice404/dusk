@paradigm procedural

// An empty struct has no fields, so C cannot size it at the boundary. A foreign
// signature that takes or returns one is refused, since a zero size argument
// would silently vanish and shift every following parameter one register early.
struct E { }

foreign "C" {
    func take_e(x: E, tail: int64) -> int64
}

func main() -> int64 {
    println(take_e(E { }, 7))
    return 0
}
