@paradigm procedural

// A float32 field is barred from a boundary struct. Keeping it out means an SSE
// eightbyte is always exactly one float64 and never a packed <2 x float>, so the
// classifier never has to lane-pack two floats into one register.
struct Bad { x: float32, y: int64 }

foreign "C" {
    func f(b: Bad) -> int64
}

func main() -> int64 {
    return 0
}
