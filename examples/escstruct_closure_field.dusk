// A struct returned by value with a closure field capturing a frame local. The
// closure's environment sits on mk's frame, so returning the struct that holds
// it is rejected at the field.
@paradigm procedural
@paradigm functional
struct Holder { f: (int64) -> int64 }
func mk() -> Holder {
    base: int64 = 100
    add := lambda (x: int64) -> int64 { return x + base }
    return Holder { f: add }
}
func main() -> int32 {
    h := mk()
    println(h.f(5))
    return 0
}
