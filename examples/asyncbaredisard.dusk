@paradigm procedural
@import std.async.future

// A bare call of an async func mints a future that is dropped before it can
// ever be awaited or released.
async func g() -> int64 {
    return 1
}

async func amain() -> int64 {
    g()
    return 1
}

func main() -> int32 {
    r := async_run(amain())
    println(r)
    return 0
}
