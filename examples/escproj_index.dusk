// Projecting an element out of a local array of slices. grid holds slices into a
// local array; returning grid[0] extracts a frame-local view.
@paradigm procedural
func mk() -> int64[] {
    a: int64[3] = [1, 2, 3]
    grid: int64[][2] = [a[0..2], a[0..1]]
    return grid[0]
}
func main() -> int32 {
    r := mk()
    println(r[0])
    return 0
}
