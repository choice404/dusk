// FIX-C accept: a bound error handed directly to a parameter declared `error` is
// that callee's to inspect, so the hand-off discharges the must-handle obligation.
@paradigm procedural

func fail() -> (int64, error) {
    return (0, error { message: "boom" })
}

func sink(err: error) -> void {
    err.ignore()
    println("sunk")
}

func main() -> int32 {
    v, e := fail()
    println(v)
    sink(e)
    return 0
}
