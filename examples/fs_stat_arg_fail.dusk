// file_stat takes a path as a string, since every foreign call underneath it
// crosses through cbuf; a bare integer is a type mismatch at the call, not
// a coercion.
@paradigm procedural

@import std.fs

func main() -> int32 {
    st, e := file_stat(42)
    e.ignore()
    println(st.size)
    return 0
}
