// A qualified enum constructor with a mistyped payload. `Opt.Some` declares an
// int64 payload, so `Opt.Some(true)` hands a bool where the int belongs and is
// refused at the constructor site, rather than constructing a mistyped value the
// match arm would then read back at the wrong width.
@paradigm procedural

enum Opt { Some(v: int64), None }

func main() -> int32 {
    o := Opt.Some(true)
    match o {
        Some(v) => println(v),
        None    => println(-1),
    }
    return 0
}
