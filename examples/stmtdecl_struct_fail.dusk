@paradigm procedural

@import std.io

// A struct declaration inside a function body is a top-level item in the wrong
// place. The parser reports the one misplaced keyword and recovers past the whole
// struct, so the legal statements that follow parse cleanly with no error cascade.
func main() -> int64 {
    struct Point { x: int64, y: int64 }
    n: int64 = 9
    print_int(n)
    return 0
}
