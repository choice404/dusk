@paradigm procedural
@import std.map
@import std.functional.maybe

// map_take of an absent key faults by name rather than returning a garbage value;
// probe with map_has first when a key may be missing.
func main() -> int32 {
    m: *Map<string, int64> = alloc(map_new())
    map_put(m, "a", 1)
    println(map_len(m))
    v: int64 = map_take(m, "z")
    println(v)
    map_free(m)
    free(m)
    return 0
}
