// `+` concatenates strings into a fresh heap string, chains left to right,
// and `+=` on a mut string rebinds it to a new concatenation each time.
@paradigm procedural

@import std.string

func main() -> int32 {
    println("hello, " + "world")

    chain := "a" + "!" + "?"
    println(chain)

    mut s: string = "x"
    s += "y"
    s += "z"
    println(s)
    println(str_len(s))
    free(s)
    return 0
}
