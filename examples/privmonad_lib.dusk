// A monad whose struct is exported but whose bind and unit are not. A `do`
// block over it from another file must not reach the private pair.
@paradigm functional

export struct W<T> {
    v: T,
}

monad W {
    func bind<A, B>(m: W<A>, f: (A) -> W<B>) -> W<B> {
        return f(m.v)
    }
    func unit<A>(x: A) -> W<A> {
        return W { v: x }
    }
}
