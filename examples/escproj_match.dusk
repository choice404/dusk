// A match arm that projects an escaping payload. e wraps a slice into a local
// array; the arm returns the payload r, which views the dead frame.
@paradigm procedural
enum E { V(rows: int64[]), N }
func mk() -> int64[] {
    a: int64[3] = [1, 2, 3]
    e := E.V(a[0..2])
    return match e { V(r) => { r } N => { a[0..1] } }
}
func main() -> int32 {
    r := mk()
    println(r[0])
    return 0
}
