// A variadic foreign function never becomes a value: the indirect call would
// drop the C variadic ABI contract, so the checker demands a direct call.
@paradigm procedural

@import std.string

foreign "C" {
    func printf(fmt: *raw char, ...) -> int32
}

func main() -> int32 {
    f := printf
    f(cbuf("hi\n"))
    return 0
}
