// A nested carrier laundered through a binding. w holds a struct whose enum
// field wraps a local slice; the escape flag propagates through the binding, so
// returning w is rejected.
@paradigm procedural
enum E { V(rows: int64[]), N }
struct W { e: E }
func mk() -> W {
    a: int64[3] = [1, 2, 3]
    w := W { e: E.V(a[0..2]) }
    return w
}
func main() -> int32 {
    r := mk()
    match r.e {
        V(v) => { println(v[0]) }
        N => { println(0) }
    }
    return 0
}
