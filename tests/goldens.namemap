# Parser termination harvest (tests/parser_termination.rs): the Rust suite's
# per-parse 5 second bound becomes the runner's own timeout wrapper; each
# record asserts bounded termination plus a clean reject.
parser_termination::corpus_all_terminates_and_is_rejected -> parseterm_01..parseterm_13 (representative harvest, one per malformed family)
parser_termination::remaining_tests -> covered by the same harvest; the generated flood and truncation families keep parseterm_12/parseterm_13 as their fixed representatives
