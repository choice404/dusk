// testrun builtins: the special modes, checks that need more than one command and
// so cannot be expressed as a single run line. installed_layout is the first,
// mirroring the Rust golden that proves a packaged install resolves its stdlib and
// runtime through the share directory. The dawn family is named but not yet
// implemented; each fails loudly rather than passing as a no op, since the dawn
// port defines the interface those checks will drive.

@paradigm procedural

@import std.io
@import std.string
@import std.os
@import manifest
@import exec

// Strips trailing blanks and newlines from a captured line, so the path mktemp
// prints reads clean into a command.
func trim_end(s: string) -> string {
    mut n: int64 = str_len(s)
    while n > 0 {
        c: char = s[n - 1]
        if c == 10 || c == 13 || c == 32 || c == 9 {
            n = n - 1
        } else {
            return substring(s, 0, n)
        }
    }
    return substring(s, 0, 0)
}

// The minimal program the installed layout check compiles and runs. It imports
// one symbol from std.io, so a clean run proves the installed compiler found the
// stdlib under share, and its output pins the run end to end.
func hello_source() -> string {
    mut s: string = "@paradigm procedural\n"
    s += "@import std.io.print_line\n"
    s += "func main() -> int32 {\n"
    s += "    print_line(\"hello, world\")\n"
    s += "    return 0\n"
    s += "}\n"
    return s
}

// Builds a throwaway install prefix, copies the compiler under test into its bin,
// and copies the stdlib and runtime under share/dusk-lang, exactly the packaged
// layout. Then it runs a hello program from inside the prefix with DUSK_HOME
// unset, so the only way the compiler finds its assets is the walk from its own
// executable up to the share directory. A mismatch or a non zero exit fails; the
// prefix is removed either way. Returns the empty string on success.
func installed_layout(bin: string) -> string {
    mk: int64 = run("mkdir -p target/testrun; mktemp -d > target/testrun/prefix.txt")
    if mk != 0 {
        return "could not run mktemp for a temp prefix"
    }
    prefix: string = trim_end(slurp("target/testrun/prefix.txt"))
    if str_eq(prefix, "") {
        return "mktemp produced no prefix path"
    }
    qp: string = quote(prefix)
    qbin: string = quote(bin)
    setup: *StringBuilder = alloc(sb_new())
    sb_push(setup, "mkdir -p ")
    sb_push(setup, qp)
    sb_push(setup, "/bin ")
    sb_push(setup, qp)
    sb_push(setup, "/share/dusk-lang && cp ")
    sb_push(setup, qbin)
    sb_push(setup, " ")
    sb_push(setup, qp)
    sb_push(setup, "/bin/dusk && cp -r lib ")
    sb_push(setup, qp)
    sb_push(setup, "/share/dusk-lang/ && cp -r runtime ")
    sb_push(setup, qp)
    sb_push(setup, "/share/dusk-lang/")
    setup_line: string = substring(sb_cstr(setup), 0, sb_size(setup))
    sb_free(setup)
    free(setup)
    sc: int64 = run(setup_line)
    free(setup_line)
    free(qbin)
    if sc != 0 {
        run_teardown(qp)
        free(qp)
        return "could not build the fake install prefix"
    }
    we: error = write_file(prefix + "/hello.dusk", hello_source())
    we.ignore()
    result: string = run_installed(prefix, qp)
    run_teardown(qp)
    free(qp)
    return result
}

// Removes the temp prefix, quoted.
func run_teardown(qp: string) -> void {
    line: string = "rm -rf " + qp
    rc: int64 = run(line)
    free(line)
    if rc != 0 {
        printerr("testrun: could not remove the temp prefix")
    }
}

// Runs the hello program from inside the prefix with DUSK_HOME unset and checks
// the output byte for byte. cwd is the prefix, so the compiler cannot reach the
// repository stdlib through the working directory and must resolve it through the
// installed share directory alone.
func run_installed(prefix: string, qp: string) -> string {
    run_line: *StringBuilder = alloc(sb_new())
    sb_push(run_line, "cd ")
    sb_push(run_line, qp)
    sb_push(run_line, " && env -u DUSK_HOME ")
    sb_push(run_line, qp)
    sb_push(run_line, "/bin/dusk run hello.dusk > ")
    sb_push(run_line, qp)
    sb_push(run_line, "/out.txt 2> ")
    sb_push(run_line, qp)
    sb_push(run_line, "/err.txt; echo $? > ")
    sb_push(run_line, qp)
    sb_push(run_line, "/code.txt")
    line: string = substring(sb_cstr(run_line), 0, sb_size(run_line))
    sb_free(run_line)
    free(run_line)
    rc: int64 = run(line)
    free(line)
    if rc != 0 {
        return "the harness could not run the installed compiler"
    }
    code: int64 = slurp_int(prefix + "/code.txt")
    out: string = slurp(prefix + "/out.txt")
    if code != 0 {
        return "the installed compiler exited with code " + int_to_string(code)
    }
    if !str_eq(out, "hello, world\n") {
        return "installed run printed '" + out + "', want 'hello, world\\n'"
    }
    return ""
}

// Builds examples/embed_lib.dusk as a C library with the compiler under test,
// links the C host examples/embed_host.c against the archive with clang, runs it,
// and checks its output byte for byte. This proves the end to end embedding story:
// a dusk module compiled with build --lib is callable from a C program through the
// generated header. Every stage failure returns a named message; a clean run
// returns the empty string. Artifacts land under target for inspection.
func embed_c_lib(bin: string) -> string {
    md: int64 = run("mkdir -p target/testrun")
    if md != 0 {
        return "could not make target/testrun"
    }
    qbin: string = quote(bin)
    bcmd: string = qbin + " build --lib examples/embed_lib.dusk > target/testrun/embed_build.txt 2>&1"
    bc: int64 = run(bcmd)
    free(bcmd)
    if bc != 0 {
        return "dusk build --lib failed: " + slurp("target/testrun/embed_build.txt")
    }
    cc: int64 = run("clang examples/embed_host.c -Itarget/dusk-out -Ltarget/dusk-out -lembed_lib -pthread -lm -o target/testrun/embed_host > target/testrun/embed_cc.txt 2>&1")
    if cc != 0 {
        return "clang could not link the C host against libembed_lib.a: " + slurp("target/testrun/embed_cc.txt")
    }
    rc: int64 = run("target/testrun/embed_host > target/testrun/embed_out.txt 2>&1; echo $? > target/testrun/embed_code.txt")
    if rc != 0 {
        return "the harness could not run the embedded host"
    }
    code: int64 = slurp_int("target/testrun/embed_code.txt")
    if code != 0 {
        return "the embedded host exited with code " + int_to_string(code)
    }
    out: string = slurp("target/testrun/embed_out.txt")
    want: string = "add=42\nscale=4.50\nsum=10\n"
    if !str_eq(out, want) {
        return "embedded host printed '" + out + "', want '" + want + "'"
    }
    free(qbin)
    return ""
}

// Runs one faulting export and checks that it aborted with the expected message on
// stderr. A dusk fault kills the process by signal, so the captured exit code is
// non-zero; the empty string means the fault behaved as required.
func expect_fault(cmd: string, want_err: string, tag: string) -> string {
    line: string = cmd + " > target/testrun/efault_out.txt 2> target/testrun/efault_err.txt; echo $? > target/testrun/efault_code.txt"
    rc: int64 = run(line)
    free(line)
    if rc != 0 {
        return "the harness could not run the " + tag + " host"
    }
    code: int64 = slurp_int("target/testrun/efault_code.txt")
    if code == 0 {
        return "the " + tag + " export returned instead of faulting"
    }
    err: string = slurp("target/testrun/efault_err.txt")
    if !str_contains(err, want_err) {
        return "the " + tag + " fault printed '" + err + "', want a line containing '" + want_err + "'"
    }
    return ""
}

// Builds examples/embed_fault_lib.dusk as a C library, links the fault host against
// it, and drives each faulting export from C: an out of bounds index and a
// collector mint in library mode. Each must abort the process by name, proving a
// dusk fault crosses the export boundary as a clean abort rather than corruption.
func embed_c_fault(bin: string) -> string {
    md: int64 = run("mkdir -p target/testrun")
    if md != 0 {
        return "could not make target/testrun"
    }
    qbin: string = quote(bin)
    bcmd: string = qbin + " build --lib examples/embed_fault_lib.dusk > target/testrun/efault_build.txt 2>&1"
    bc: int64 = run(bcmd)
    free(bcmd)
    free(qbin)
    if bc != 0 {
        return "dusk build --lib failed: " + slurp("target/testrun/efault_build.txt")
    }
    cc: int64 = run("clang examples/embed_fault_host.c -Itarget/dusk-out -Ltarget/dusk-out -lembed_fault_lib -pthread -lm -o target/testrun/efault_host > target/testrun/efault_cc.txt 2>&1")
    if cc != 0 {
        return "clang could not link the fault host against libembed_fault_lib.a: " + slurp("target/testrun/efault_cc.txt")
    }
    r1: string = expect_fault("target/testrun/efault_host boom", "index out of bounds", "bounds")
    if str_len(r1) > 0 {
        return r1
    }
    r2: string = expect_fault("target/testrun/efault_host collect", "the collector runs on the main thread only", "collector")
    if str_len(r2) > 0 {
        return r2
    }
    return ""
}

// Dispatches a special record to its handler. A dawn special is named but not
// implemented and fails loudly, and an unrecognized special name fails the same
// way rather than silently passing.
export func run_special(rec: Record, bin: string) -> string {
    name: string = rec.special
    if str_eq(name, "installed_layout") {
        return installed_layout(bin)
    }
    if str_eq(name, "embed_c_lib") {
        return embed_c_lib(bin)
    }
    if str_eq(name, "embed_c_fault") {
        return embed_c_fault(bin)
    }
    if starts_with(name, "dawn_") {
        return "special '" + name + "' not implemented"
    }
    return "unknown special '" + name + "'"
}
