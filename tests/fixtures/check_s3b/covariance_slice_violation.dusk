@paradigm oop
@paradigm procedural

interface Shape {
    area() -> int64
}

struct Sq {
    side: int64,
}

impl Shape for Sq {
    func area() -> int64 {
        return self.side * self.side
    }
}

func take(shapes: Shape[]) -> int64 {
    return shapes[0].area()
}

func f(squares: Sq[]) -> int64 {
    return take(squares)
}
