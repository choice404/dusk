@paradigm procedural
@import std.concurrent.channel

struct Cell { rows: int64[] }

func relay(ch: Channel<*Cell>, c: *Cell) -> void { chan_send(ch, c) }

func bad(ch: Channel<*Cell>) -> void {
    c: *Cell = alloc(Cell { rows: [0] })
    local: int64[4] = [1, 2, 3, 4]
    (*c).rows = local[0..4]
    relay(ch, c)
}

func main() -> int64 { return 0 }
