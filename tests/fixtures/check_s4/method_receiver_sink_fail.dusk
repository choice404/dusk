@paradigm procedural
@paradigm oop
@import std.concurrent.channel

struct Cell { rows: int64[] }

interface Sendable { ship(ch: Channel<*Cell>) -> void }

impl Sendable for Cell {
    func ship(ch: Channel<*Cell>) -> void {
        e := chan_send(ch, self)
        e.ignore()
    }
}

func send_one(ch: Channel<*Cell>) -> void {
    c: *Cell = alloc(Cell { rows: [0] })
    local: int64[4] = [111, 222, 333, 444]
    (*c).rows = local[0..4]
    c.ship(ch)
}

func main() -> int64 { return 0 }
