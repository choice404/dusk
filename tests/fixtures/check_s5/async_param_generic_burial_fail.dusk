// A slice buried behind a generic type argument on an async parameter would view
// the caller's frame the task outlives. The surface erased walk cannot see it; the
// forced-future pass over the ground signature does.
@paradigm procedural
@import std.async.future
@import std.async.loop
@import std.io

struct Box<T> { x: T }

async func g(b: Box<int64[]>) -> int64 { return 1 }

async func amain() -> int64 { return 1 }

func main() -> int32 {
    le := loop_init()
    le.ignore()
    r := async_run(amain())
    loop_free()
    println(r)
    return 0
}
