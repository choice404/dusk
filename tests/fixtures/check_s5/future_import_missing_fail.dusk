// Calling an async func mints a Future the source never spells, so the Future
// struct must be in scope. Without the import the forced-future pass reports it.
@paradigm procedural
@import std.async.loop
@import std.io

async func amain() -> int64 { return 1 }

func main() -> int32 {
    r := async_run(amain())
    println(r)
    return 0
}
