// A plain generic instantiated at two element types. Mono emits one mangled copy
// per distinct type argument and drops the generic definition. An accept case whose
// mono dump names id$int64 and id$float64 and no bare id.
@paradigm procedural
@import std.io

func id<T>(x: T) -> T { return x }

func main() -> int32 {
    a := id(1)
    b := id(2.0)
    println(a)
    println(b)
    return 0
}
