// A slice buried behind a generic struct field reaches a channel element only once
// the concrete type is known at instantiation. A view of the sending frame would
// dangle in the receiver, so the mono channel-element ban rejects it.
@paradigm procedural
@import std.io

struct Wrap { s: int64[] }

func chan_new<T>(cap: int64) -> T { return chan_new(cap) }

func main() -> int32 {
    w: Wrap = chan_new(1)
    println(w.s[0])
    return 0
}
