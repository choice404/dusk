// The narrow mutable-tuple class: an unannotated mut tuple whose initializer holds
// an array-literal member. The surface pass reconciles the tuple storage and mono
// stamps it onto the binding's Bind.ty, so the mono dump carries a Some type where
// the parser left None. An accept case that makes the stamp dump-visible.
@paradigm procedural
@import std.io

func main() -> int32 {
    mut pair := ([1, 2, 3], 0)
    pair = ([4, 5, 6], 1)
    first, tag := pair
    println(first[0])
    println(tag)
    return 0
}
