// An async call mints a Future<int64> the source never spells. Mono forces one
// Future instance per async func, so the ground module carries a Future$int64
// item even though no line names Future<int64>. An accept case.
@paradigm procedural
@import std.async.future
@import std.async.loop
@import std.io

async func compute(n: int64) -> int64 { return n * 2 }

func main() -> int32 {
    le := loop_init()
    le.ignore()
    r := async_run(compute(21))
    loop_free()
    println(r)
    return 0
}
