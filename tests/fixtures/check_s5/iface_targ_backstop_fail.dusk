// An interface has no single ground layout, so it cannot stand in for a generic
// type parameter. Here the interface argument is inferred from a field value, a
// shape the erased surface walk cannot see, so only the mono backstop catches it.
@paradigm oop
@import std.io

interface Speaker { speak() -> int64 }

struct Dog { name: int64 }

impl Speaker for Dog {
    func speak() -> int64 { return self.name }
}

struct Box<T> { v: T }

func main() -> int32 {
    s: Speaker = Dog { name: 3 }
    b := Box { v: s }
    println(b.v.speak())
    return 0
}
