// A future element that views a frame would dangle in the awaiter. The element is
// inferred from the binding annotation, so the mono future-element ban rejects the
// mint at the instantiation site.
@paradigm procedural
@import std.io

func future_new<T>() -> T { return future_new() }

func main() -> int32 {
    s: int64[] = future_new()
    println(s[0])
    return 0
}
