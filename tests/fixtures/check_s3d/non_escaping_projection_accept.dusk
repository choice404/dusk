@paradigm procedural
@paradigm functional

struct Box { rows: int64[] }

func heap_rows() -> int64[] {
    seed: int64[2] = [6, 7]
    return map(seed[0..2], lambda (x: int64) -> int64 { return x })
}

func make() -> int64[] {
    b := Box { rows: heap_rows() }
    return b.rows
}

func main() -> int32 {
    s := make()
    println(s[0])
    return 0
}
