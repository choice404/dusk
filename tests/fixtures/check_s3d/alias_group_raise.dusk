@paradigm procedural
@paradigm functional

struct Cell { rows: int64[] }

func heap_rows() -> int64[] {
    seed: int64[2] = [8, 9]
    return map(seed[0..2], lambda (x: int64) -> int64 { return x })
}

func make() -> *Cell {
    c: *Cell = alloc(Cell { rows: heap_rows() })
    ref q := c
    local: int64[2] = [1, 2]
    (*q).rows = local[0..2]
    return c
}

func main() -> int32 {
    c := make()
    println((*c).rows[0])
    free(c)
    return 0
}
