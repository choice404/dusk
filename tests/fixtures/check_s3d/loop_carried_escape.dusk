@paradigm procedural
@paradigm functional

func heap_rows() -> int64[] {
    seed: int64[2] = [1, 2]
    return map(seed[0..2], lambda (x: int64) -> int64 { return x })
}

func make() -> int64[] {
    local: int64[2] = [3, 4]
    fv := local[0..2]
    mut out := heap_rows()
    mut tmp := heap_rows()
    mut i := 0
    while i < 2 {
        out = tmp
        tmp = fv
        i = i + 1
    }
    return out
}

func main() -> int32 {
    s := make()
    println(s[0])
    return 0
}
