// The (lo, hi, msg) dedup key, demonstrated: a slice buried behind a generic type
// argument on an async parameter escapes the surface erased walk, so the surface
// pass stays clean. Mono's forced-future pass catches the burial over the ground
// signature and reports it; the ground type pass re-runs the async signature check
// over the now-concrete struct and reports it too, at the same span. The two
// messages differ, so deduping by span alone would wrongly drop one; keying on
// (lo, hi, msg) keeps both, in emit order. A same-span message that would collapse
// on an identical triple appears once.
@paradigm procedural

@import std.async.future
@import std.async.loop
@import std.io

struct Box<T> { x: T }

async func g(b: Box<int64[]>) -> int64 { return 1 }

async func amain() -> int64 { return 1 }

func main() -> int32 {
    le := loop_init()
    le.ignore()
    r := async_run(amain())
    loop_free()
    println(r)
    return 0
}
