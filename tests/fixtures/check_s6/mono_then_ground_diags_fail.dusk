// The ground pass runs even when mono already reported: a generic `do` over a
// monad whose result element is wholly uninferable draws a mono inference
// diagnostic, and the ground types-only pass then draws a return-type mismatch at
// the same do span. The two share a span but not a message, so the (lo, hi, msg)
// dedup keeps both, in emit order: mono first, then ground.
@paradigm functional

enum Evil<T> {
    Full(v: T),
    Empty,
}

monad Evil {
    func bind<A, B>(m: Evil<A>, f: (A) -> Evil<B>) -> Evil<B> {
        match m {
            Full(a) => return f(a),
            Empty => return f(0),
        }
    }
    func unit<A>(x: A) -> Evil<A> {
        return Evil.Full(x)
    }
}

func main() -> int32 {
    r := do Evil {
        a <- Evil.Empty
        a
    }
    match r {
        Full(v) => println("full"),
        Empty => println("empty"),
    }
    return 0
}
