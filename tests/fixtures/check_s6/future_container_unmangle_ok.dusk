// Future unmangle, the visible accept: a future crosses a non-async func that
// takes and returns Future<int64>, and futures are also held in a slice. Mono
// mangles every Future<int64> to the named struct Future$int64, so in the ground
// module the parameter, the return, and the slice element all read as a plain
// named type. The ground pass unmangles each through the future table, so the
// forwarded, returned, and stored futures type-check the same shape the surface
// pass accepted. An accept case; the mono dump carries the Future$int64 item.
@paradigm procedural

@import std.async.future
@import std.async.loop
@import std.io

func forward(x: Future<int64>) -> Future<int64> {
    return x
}

func main() -> int32 {
    le := loop_init()
    le.ignore()
    a: Future<int64> = future_new()
    b: Future<int64> = forward(a)
    fs: Future<int64>[] = [b]
    v, e := await(fs[0])
    e.ignore()
    loop_free()
    println(v)
    return 0
}
