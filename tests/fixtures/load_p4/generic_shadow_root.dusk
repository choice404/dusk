// generic_shadow_lib's private struct T is renamed by privatize, but f's own
// generic parameter is also named T. The renamer's per-function skip set must
// treat f's T as the bound generic, not the private struct, so f's parameter
// and return type stay bare "T" while g's parameter and return type, which
// really do name the private struct, follow the struct's rename.
@paradigm procedural
@import generic_shadow_lib

func main() -> int32 {
    a := f(3)
    return 0
}
