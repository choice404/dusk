// add_namespace registers every dotted prefix of an import path as a callable
// namespace, so importing only a.b.c also marks the intermediate prefix a.b as
// a namespace, even though a.b names no module of its own (ns_exports has an
// entry only for a.b.c, the module actually imported). A call through that
// intermediate prefix, a.b.something(), therefore still folds to the bare
// global something(), and the private-export check is skipped for it, since
// exports has no entry keyed by "a.b" to check against.
@paradigm procedural
@import a.b.c

func main() -> int32 {
    a.b.something()
    return 0
}
