struct Future<T> { h: *void, gen: int64 }
async func one() -> int64 { return 1 }
func push2<T>(x: T, y: T) -> T { return x }
async func amain() -> int32 {
  f := one()
  g := one()
  r := push2(f, g)
  v := await r
  println(v)
  return 0
}
func main() -> int32 {
  rc := async_run(amain())
  return rc
}
