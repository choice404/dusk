interface Shape { area() -> int64 }
interface Summer { total(shapes: Shape[]) -> int64 }
struct Sq { s: int64 }
impl Shape for Sq { func area() -> int64 { return self.s } }
struct Calc { b: int64 }
impl Summer for Calc { func total(shapes: Shape[]) -> int64 { return shapes[0].area() } }
func go(s: Summer, arr: Sq[]) -> int64 { return s.total(arr) }
