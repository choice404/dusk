struct Lz<T> { run: collector<() -> T> }
func unit2<A>(x: A) -> Lz<A> { return Lz { run: collector<() -> A>(lambda () -> A { return x }) } }
func bind<A, B>(m: Lz<A>, k: collector<(A) -> Lz<B>>) -> Lz<B> { return unit2(0) }
func mk() -> Lz<int64> { return unit2(5) }
func main() -> int32 {
r := bind(mk(), lambda (a: int64) -> Lz<float64> { return unit2(2.0) })
return 0
}
