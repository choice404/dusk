enum Res<T, E> { Ok(v: T), Err(e: E) }
func bind<A, B>(m: Res<A, string>, f: (A) -> Res<B, string>) -> Res<B, string> {
match m { Ok(a) => return f(a), Err(e) => return Res.Err(e) }
}
func unit<A>(x: A) -> Res<A, string> { return Res.Ok(x) }
func main() -> int32 {
r := bind(Res.Ok(1), lambda (a: int64) -> Res<int64, string> {
return bind(Res.Ok(20), lambda (b: int64) -> Res<int64, string> {
return unit(a + b)
})
})
return 0
}
