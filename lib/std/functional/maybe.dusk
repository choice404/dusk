// std.functional.maybe: an optional value, Some or None.

export enum Maybe<T> {
    Some(v: T),
    None,
}

export func is_some<T>(m: Maybe<T>) -> bool {
    match m {
        Some(v) => return true,
        None => return false,
    }
}

export func unwrap_or<T>(m: Maybe<T>, fallback: T) -> T {
    match m {
        Some(v) => return v,
        None => return fallback,
    }
}
