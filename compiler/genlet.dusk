// genlet: scalar local storage and assignment lowering for dusk1.
//
// Locals are represented as stack slots in the entry block. This matches the
// stage0 lifetime shape and gives assignment a stable place to update.

@paradigm procedural

@import std.string
@import std.vector
@import std.map
@import std.functional.maybe
@import ast
@import cty
@import emit
@import genctx
@import genstate
@import genexpr
@import genagg
@import genptr
@import genplace

// Copies a string literal's decoded bytes into a char array slot through
// llvm.memcpy. The interned global carries a trailing NUL that is deliberately
// not copied; the checker already matched the byte length to the array.
func gl_char_lit_copy(s: *GenFuncState, ptr: string, len: int64, init: ExprNode) -> void {
    a: *Ast = (*(*s).ctx).ast
    g: string = emit_cstring_body((*s).module, ast_name(a, init.a))
    b: *StringBuilder = alloc(sb_new())
    sb_push(b, "call void @llvm.memcpy.p0.p0.i64(ptr ")
    sb_push(b, ptr)
    sb_push(b, ", ptr ")
    sb_push(b, g)
    sb_push(b, ", i64 ")
    sb_push_int(b, len)
    sb_push(b, ", i1 false)")
    text: string = gs_built(b)
    sb_free(b)
    free(b)
    line((*s).fb, text)
    free(text)
}

// Whether the lowered type is a char array, the target of the literal copy.
func gl_is_char_array(c: *CTyArena, ty: int64) -> bool {
    n: CTyNode = vec_get(cty_nodes(c), ty)
    if n.kind != ctyk_array() { return false }
    en: CTyNode = vec_get(cty_nodes(c), n.a)
    return en.kind == ctyk_char()
}

// Lowers a scalar binding and records its stack slot for later loads and stores.
export func gen_let(s: *GenFuncState, sid: int64) -> void {
    a: *Ast = (*(*s).ctx).ast
    st: StmtNode = vec_get((*a).stmts, sid)
    c: *CTyArena = genctx_ctys((*s).ctx)
    if st.b != 1 {
        v0: Val = gen_expr(s, st.c)
        mut di: int64 = 0
        while di < st.b {
            ety: int64 = cty_tuple_elem(c, v0.ty, di)
            d: string = next_tmp((*s).fb)
            vll: string = cty_ll(c, v0.ty)
            eb: *StringBuilder = alloc(sb_new())
            sb_push(eb, d)
            sb_push(eb, " = extractvalue ")
            sb_push(eb, vll)
            sb_push_char(eb, 32)
            sb_push(eb, v0.op)
            sb_push(eb, ", ")
            sb_push_int(eb, di)
            etx: string = gs_built(eb)
            sb_free(eb)
            free(eb)
            line((*s).fb, etx)
            free(etx)
            dbid: int64 = vec_get((*a).kids, st.a + di)
            db: BindNode = vec_get((*a).binds, dbid)
            mut dty: int64 = ety
            if db.ty >= 0 { dty = cty_lower_ast(c, a, db.ty) }
            av0: Val = adapt(s, Val { ty: ety, op: d }, dty)
            dp: string = gen_alloca(s, dty)
            gen_store_slot(s, dty, av0.op, dp)
            map_put((*s).locals, gs_copy(ast_name(a, db.name)), LocalVal { ty: dty, op: dp })
            di = di + 1
        }
        return
    }
    bid: int64 = vec_get((*a).kids, st.a)
    bind: BindNode = vec_get((*a).binds, bid)
    init: ExprNode = vec_get((*a).exprs, st.c)
    mut ty: int64 = cty_void(c)
    mut v: Val = Val { ty: cty_void(c), op: gs_copy("") }
    if bind.ty >= 0 {
        ty = cty_lower_ast(c, a, bind.ty)
        tn: CTyNode = vec_get(cty_nodes(c), ty)
        mut special_alloc: bool = false
        if init.kind == xk_call() {
            callee: ExprNode = vec_get((*a).exprs, init.a)
            if callee.kind == xk_ident() {
                if str_eq(ast_name(a, callee.a), "alloc") {
                    if tn.kind == ctyk_ptr() {
                        if init.c == 0 { v = alloc_of(s, tn.a, false, Val { ty: tn.a, op: gs_copy("0") }) }
                        else { v = alloc_of(s, tn.a, true, gen_expr(s, vec_get((*a).kids, init.b))) }
                        special_alloc = true
                    }
                }
            }
        }
        if special_alloc {
        } else if init.kind == xk_array() {
            if tn.kind == ctyk_array() { v = gen_array_lit(s, init, tn.a) }
            else if tn.kind == ctyk_slice() { v = slice_from_array(s, gen_array_lit(s, init, tn.a), init.b) }
            else { v = gen_expr(s, st.c) }
        } else if init.kind == xk_str() && gl_is_char_array(c, ty) {
            // `s: char[N] = "lit"` copies the literal's bytes into the slot.
            ptr0: string = gen_alloca(s, ty)
            gl_char_lit_copy(s, ptr0, tn.b, init)
            map_put((*s).locals, gs_copy(ast_name(a, bind.name)), LocalVal { ty: ty, op: ptr0 })
            return
        } else { v = gen_expr(s, st.c) }
    } else {
        v = gen_expr(s, st.c)
        ty = v.ty
    }
    if cty_is_stub(c, ty) {
        emit_error((*s).module, "unsupported codegen type in let")
        return
    }
    out: string = adapt(s, v, ty).op
    ptr: string = gen_alloca(s, ty)
    gen_store_slot(s, ty, out, ptr)
    map_put((*s).locals, gs_copy(ast_name(a, bind.name)), LocalVal { ty: ty, op: ptr })
}

// Lowers `name = expr` for scalar locals; other places remain aggregate-owned.
export func gen_assign(s: *GenFuncState, lhs: int64, rhs: int64) -> void {
    p: Place = gen_place(s, lhs)
    if !p.ok {
        emit_error((*s).module, "unsupported assignment target")
        return
    }
    a: *Ast = (*(*s).ctx).ast
    r: ExprNode = vec_get((*a).exprs, rhs)
    c: *CTyArena = genctx_ctys((*s).ctx)
    if r.kind == xk_str() && gl_is_char_array(c, p.ty) {
        // A char array place assigned a string literal copies the literal's
        // bytes, the same lowering as the let form.
        pn: CTyNode = vec_get(cty_nodes(c), p.ty)
        gl_char_lit_copy(s, p.ptr, pn.b, r)
        return
    }
    v: Val = gen_expr(s, rhs)
    out: string = adapt(s, v, p.ty).op
    gen_store_slot(s, p.ty, out, p.ptr)
}

// Lowers scalar compound assignment by loading once, combining, and storing back.
export func gen_assign_op(s: *GenFuncState, op: int64, lhs: int64, rhs: int64) -> void {
    p: Place = gen_place(s, lhs)
    if !p.ok {
        emit_error((*s).module, "unsupported compound assignment target")
        return
    }
    cur: string = gen_load_slot(s, p.ty, p.ptr)
    v: Val = gen_binop_vals(s, op, Val { ty: p.ty, op: cur }, rhs)
    out: string = coerce(s, v.ty, v.op, p.ty)
    gen_store_slot(s, p.ty, out, p.ptr)
}
