    e: EnumNode = vec_get((*a).enums, id)
    sb_push(out, "Enum {\n")
    ind(out, level + 1)
    sb_push(out, "exported: ")
    push_bool(out, e.exported)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "name: ")
    push_string(out, ast_name(a, e.name))
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "generics: ")
    render_name_kids(out, a, e.generics_off, e.generics_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "variants: ")
    render_variant_list(out, a, e.variants_off, e.variants_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level)
    sb_push_char(out, 125)
}

