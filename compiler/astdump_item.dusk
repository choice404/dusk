// astdump_item: item record rendering for the canonical parse dump.

@paradigm procedural

@import std.string
@import std.vector
@import ast
@import astdumpty
@import astdump2

func ind(out: *StringBuilder, n: int64) -> void {
    mut i: int64 = 0
    while i < n {
        sb_push(out, "    ")
        i = i + 1
    }
}

func push_bool(out: *StringBuilder, b: bool) -> void {
    if b { sb_push(out, "true") } else { sb_push(out, "false") }
}

func push_string(out: *StringBuilder, s: string) -> void {
    sb_push_char(out, 34)
    sb_push(out, s)
    sb_push_char(out, 34)
}

func render_span(out: *StringBuilder, lo: int64, hi: int64, level: int64) -> void {
    sb_push(out, "Span {\n")
    ind(out, level + 1)
    sb_push(out, "lo: ")
    sb_push_int(out, lo)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "hi: ")
    sb_push_int(out, hi)
    sb_push(out, ",\n")
    ind(out, level)
    sb_push_char(out, 125)
}

func render_func(out: *StringBuilder, a: *Ast, id: int64, level: int64) -> void {
    f: FuncNode = vec_get((*a).funcs, id)
    sb_push(out, "Func {\n")
    ind(out, level + 1)
    sb_push(out, "exported: ")
    push_bool(out, f.exported)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "is_async: ")
    push_bool(out, f.is_async)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "name: ")
    push_string(out, ast_name(a, f.name))
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "span: ")
    render_span(out, f.lo, f.hi, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "generics: ")
    render_name_kids(out, a, f.generics_off, f.generics_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "params: ")
    render_param_list(out, a, f.params_off, f.params_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "ret: ")
    render_type(out, a, f.ret, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "body: ")
    render_block(out, a, f.body, level + 1)
    sb_push(out, ",\n")
    ind(out, level)
    sb_push_char(out, 125)
}

func render_struct_item(out: *StringBuilder, a: *Ast, id: int64, level: int64) -> void {
    s: StructNode = vec_get((*a).structs, id)
    sb_push(out, "Struct {\n")
    ind(out, level + 1)
    sb_push(out, "exported: ")
    push_bool(out, s.exported)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "name: ")
    push_string(out, ast_name(a, s.name))
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "generics: ")
    render_name_kids(out, a, s.generics_off, s.generics_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "fields: ")
    render_field_list(out, a, s.fields_off, s.fields_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level)
    sb_push_char(out, 125)
}

func render_variant(out: *StringBuilder, a: *Ast, id: int64, level: int64) -> void {
    v: VariantNode = vec_get((*a).variants, id)
    sb_push(out, "Variant {\n")
    ind(out, level + 1)
    sb_push(out, "name: ")
    push_string(out, ast_name(a, v.name))
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "fields: ")
    render_field_list(out, a, v.fields_off, v.fields_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level)
    sb_push_char(out, 125)
}

func render_variant_list(out: *StringBuilder, a: *Ast, off: int64, len: int64, level: int64) -> void {
    if len == 0 {
        sb_push(out, "[]")
        return
    }
    sb_push(out, "[\n")
    mut i: int64 = 0
    while i < len {
        ind(out, level + 1)
        render_variant(out, a, vec_get((*a).kids, off + i), level + 1)
        sb_push(out, ",\n")
        i = i + 1
    }
    ind(out, level)
    sb_push_char(out, 93)
}

