    ind(out, level + 1)
    sb_push(out, "name: ")
    push_string(out, ast_name(a, it.name))
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "generics: ")
    render_name_kids(out, a, it.generics_off, it.generics_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "methods: ")
