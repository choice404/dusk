func render_func_list(out: *StringBuilder, a: *Ast, off: int64, len: int64, level: int64) -> void {
    if len == 0 {
        sb_push(out, "[]")
        return
    }
    sb_push(out, "[\n")
    mut i: int64 = 0
    while i < len {
        ind(out, level + 1)
        render_func(out, a, vec_get((*a).kids, off + i), level + 1)
        sb_push(out, ",\n")
        i = i + 1
    }
    ind(out, level)
    sb_push_char(out, 93)
}

func render_optional_name(out: *StringBuilder, a: *Ast, id: int64, level: int64) -> void {
    if id < 0 {
        sb_push(out, "None")
    } else {
        sb_push(out, "Some(\n")
        ind(out, level + 1)
        push_string(out, ast_name(a, id))
        sb_push(out, ",\n")
        ind(out, level)
        sb_push_char(out, 41)
    }
}

func render_impl_item(out: *StringBuilder, a: *Ast, id: int64, level: int64) -> void {
    im: ImplNode = vec_get((*a).impls, id)
    sb_push(out, "Impl {\n")
    ind(out, level + 1)
    sb_push(out, "iface: ")
    render_optional_name(out, a, im.iface, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "ty: ")
    push_string(out, ast_name(a, im.ty))
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "span: ")
    render_span(out, im.lo, im.hi, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "methods: ")
    render_func_list(out, a, im.methods_off, im.methods_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level)
    sb_push_char(out, 125)
}

