    ff: ForeignFuncNode = vec_get((*a).foreign_funcs, id)
    sb_push(out, "ForeignFunc {\n")
    ind(out, level + 1)
    sb_push(out, "name: ")
    push_string(out, ast_name(a, ff.name))
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "params: ")
    render_param_list(out, a, ff.params_off, ff.params_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "ret: ")
    render_type(out, a, ff.ret, level + 1)
    sb_push(out, ",\n")
    ind(out, level)
    sb_push_char(out, 125)
}

func render_foreign_func_list(out: *StringBuilder, a: *Ast, off: int64, len: int64, level: int64) -> void {
    if len == 0 {
        sb_push(out, "[]")
        return
    }
    sb_push(out, "[\n")
    mut i: int64 = 0
    while i < len {
        ind(out, level + 1)
        render_foreign_func(out, a, vec_get((*a).kids, off + i), level + 1)
        sb_push(out, ",\n")
        i = i + 1
    }
    ind(out, level)
    sb_push_char(out, 93)
}

func render_foreign_item(out: *StringBuilder, a: *Ast, id: int64, level: int64) -> void {
    f: ForeignNode = vec_get((*a).foreigns, id)
    sb_push(out, "Foreign {\n")
    ind(out, level + 1)
    sb_push(out, "abi: ")
    push_string(out, ast_name(a, f.abi))
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "span: ")
    render_span(out, f.lo, f.hi, level + 1)
    sb_push(out, ",\n")
    ind(out, level + 1)
    sb_push(out, "funcs: ")
    render_foreign_func_list(out, a, f.funcs_off, f.funcs_len, level + 1)
    sb_push(out, ",\n")
    ind(out, level)
    sb_push_char(out, 125)
}

func render_item_body(out: *StringBuilder, a: *Ast, it: ItemNode, level: int64) -> void {
    if it.kind == ik_func() {
        render_func(out, a, it.id, level)
    } else if it.kind == ik_struct() {
        render_struct_item(out, a, it.id, level)
    } else if it.kind == ik_enum() {
        render_enum_item(out, a, it.id, level)
    } else if it.kind == ik_interface() {
        render_interface_item(out, a, it.id, level)
    } else if it.kind == ik_impl() {
        render_impl_item(out, a, it.id, level)
    } else {
        render_foreign_item(out, a, it.id, level)
    }
}

func item_name(kind: int64) -> string {
    if kind == ik_func() { return "Func" }
    if kind == ik_struct() { return "Struct" }
    if kind == ik_enum() { return "Enum" }
    if kind == ik_interface() { return "Interface" }
    if kind == ik_impl() { return "Impl" }
    return "Foreign"
}

export func render_all_items(out: *StringBuilder, a: *Ast, level: int64) -> void {
    items: *Vector<ItemNode> = (*a).items
    if vec_len(items) == 0 {
        sb_push(out, "[]")
        return
    }
    sb_push(out, "[\n")
    mut i: int64 = 0
    while i < vec_len(items) {
        it: ItemNode = vec_get(items, i)
        ind(out, level + 1)
        sb_push(out, item_name(it.kind))
        sb_push(out, "(\n")
        ind(out, level + 2)
        render_item_body(out, a, it, level + 2)
        sb_push(out, ",\n")
        ind(out, level + 1)
        sb_push(out, "),\n")
        i = i + 1
    }
    ind(out, level)
    sb_push_char(out, 93)
}
