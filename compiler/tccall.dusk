    b: *StringBuilder = alloc(sb_new())
    sb_push(b, name)
    sb_push(b, " takes one argument, a lambda literal of type () -> void")
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    return out
}

