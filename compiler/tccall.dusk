    b: *StringBuilder = alloc(sb_new())
    sb_push(b, name)
    sb_push(b, " takes a lambda literal written at the call site; wrap a closure variable as lambda () -> void { g() }")
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    return out
}

func task_shape_msg(name: string) -> string {
    b: *StringBuilder = alloc(sb_new())
    sb_push(b, "a lambda passed to ")
    sb_push(b, name)
    sb_push(b, " takes no parameters and returns void; pass data by capture and results through a channel")
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
