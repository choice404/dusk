// tccall: call inference, builtin call shapes, and constructor checks.

@paradigm procedural

@import std.string
@import std.vector
@import std.map
@import std.functional.maybe
@import ast
@import ty
@import tysigs
@import tcstate
@import tcscope
@import tcbin
@import tciface
@import tcown
@import tcesc

func call_msg_count(want: int64, got: int64) -> string {
    b: *StringBuilder = alloc(sb_new())
    sb_push(b, "expected ")
    sb_push_int(b, want)
    sb_push(b, " argument(s), found ")
    sb_push_int(b, got)
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    return out
}

func arg_wrong_msg(i: int64) -> string {
    b: *StringBuilder = alloc(sb_new())
    sb_push(b, "argument ")
    sb_push_int(b, i + 1)
    sb_push(b, " has the wrong type")
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    return out
}

func func_builtin_ret(tc: *TypeChecker, name: string) -> int64 {
    t: *TyArena = (*tc).ty
    if str_eq(name, "read_file") || str_eq(name, "read_line") || str_eq(name, "read_all") {
        xs: *Vector<int64> = alloc(vec_new())
        vec_push(xs, ty_str(t))
        vec_push(xs, ty_error(t))
        return ty_tuple(t, xs)
    }
    if str_eq(name, "parse_float") {
        ys: *Vector<int64> = alloc(vec_new())
        vec_push(ys, ty_float(t, 64))
        vec_push(ys, ty_error(t))
        return ty_tuple(t, ys)
    }
    if str_eq(name, "write_file") { return ty_error(t) }
    if str_eq(name, "cstr") { return ty_str(t) }
    if str_eq(name, "sizeof") { return ty_int(t, 64) }
    return -1
}

func builtin_arity(tc: *TypeChecker, name: string, got: int64, lo: int64, hi: int64) -> bool {
    mut want: int64 = -1
    if str_eq(name, "fold") { want = 3 }
    if str_eq(name, "map") || str_eq(name, "filter") || str_eq(name, "reduce") || str_eq(name, "foreach") { want = 2 }
    if want < 0 { return false }
    if got != want {
        b: *StringBuilder = alloc(sb_new())
        sb_push(b, name)
        sb_push(b, " takes ")
        sb_push_int(b, want)
        sb_push(b, " argument(s), but ")
        sb_push_int(b, got)
        sb_push(b, " were given")
        out: string = substring(sb_cstr(b), 0, sb_size(b))
        sb_free(b)
        free(b)
        tc_emit(tc, out, lo, hi)
    }
    return true
}

func base_lookup(tc: *TypeChecker, id: int64) -> int64 {
    a: *Ast = (*tc).ast
    e: ExprNode = vec_get((*a).exprs, id)
    if e.kind == xk_ident() {
        return lookup(tc, ast_name(a, e.a))
    }
    if e.kind == xk_unary() && e.a == uop_deref() {
        pt: int64 = base_lookup(tc, e.b)
        pn: TyNode = ty_get((*tc).ty, pt)
        if pn.kind == tyk_ptr() || pn.kind == tyk_rawptr() { return pn.a }
    }
    return ty_unknown((*tc).ty)
}

func enum_contains_variant(tc: *TypeChecker, en: string, v: string) -> bool {
    enums: *Map<EnumSig> = (*tc).enums
    es: EnumSig = unwrap_or(map_get(enums, en), EnumSig { off: 0, len: 0 })
    sigs: *TypeSigs = (*tc).sigtab
    mut i: int64 = 0
    while i < es.len {
        if str_eq(vec_get((*sigs).names, es.off + i), v) { return true }
        i = i + 1
    }
    return false
}

func ctor_arity_msg(en: string, v: string, want: int64, got: int64) -> string {
    b: *StringBuilder = alloc(sb_new())
    sb_push_char(b, 39)
    sb_push(b, en)
    sb_push_char(b, 46)
    sb_push(b, v)
    sb_push(b, "' takes ")
    sb_push_int(b, want)
    sb_push(b, " argument(s), but ")
    sb_push_int(b, got)
    sb_push(b, " were given")
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    return out
}

func ctor_arg_msg(en: string, v: string, i: int64) -> string {
    b: *StringBuilder = alloc(sb_new())
    sb_push(b, "argument ")
    sb_push_int(b, i + 1)
    sb_push(b, " to '")
    sb_push(b, en)
    sb_push_char(b, 46)
    sb_push(b, v)
    sb_push(b, "' has the wrong type")
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    return out
}

func check_variant_ctor_args(tc: *TypeChecker, en: string, v: string, arg_off: int64, arg_len: int64, arg_tys: *Vector<int64>, span_lo: int64, span_hi: int64) -> void {
    if !enum_contains_variant(tc, en, v) { return }
    vs: VariantSig = sig_variant_for_enum((*tc).sigtab, en, v)
    if vs.len != arg_len {
        tc_emit(tc, ctor_arity_msg(en, v, vs.len, arg_len), span_lo, span_hi)
        return
    }
    a: *Ast = (*tc).ast
    mut i: int64 = 0
    while i < vs.len {
        p: int64 = sig_ty_at((*tc).sigtab, TyList { off: vs.off, len: vs.len }, i)
        av: int64 = vec_get(arg_tys, i)
        arg_id: int64 = vec_get((*a).kids, arg_off + i)
        arg: ExprNode = vec_get((*a).exprs, arg_id)
        pn: TyNode = ty_get((*tc).ty, p)
        mut skip_plain: bool = false
        if pn.kind == tyk_named() {
            ifaces: *Map<int64> = (*tc).ifaces
            if map_has(ifaces, ty_name((*tc).ty, p)) {
                skip_plain = true
            }
            structs: *Map<StructSig> = (*tc).structs
            enums: *Map<EnumSig> = (*tc).enums
            pname: string = ty_name((*tc).ty, p)
            if !map_has(structs, pname) && !map_has(enums, pname) {
                skip_plain = true
            }
        }
        if pn.kind == tyk_slice() {
            pe: TyNode = ty_get((*tc).ty, pn.a)
            if pe.kind == tyk_named() {
                ifaces2: *Map<int64> = (*tc).ifaces
                if map_has(ifaces2, ty_name((*tc).ty, pn.a)) {
                    skip_plain = true
                }
            }
        }
        if !skip_plain {
            check_int_fits(tc, arg_id, p)
            if !compat((*tc).ty, p, av) {
                tc_emit(tc, ctor_arg_msg(en, v, i), arg.lo, arg.hi)
            }
        }
        i = i + 1
    }
}

func unqualified_ctor_msg(en: string, v: string) -> string {
    b: *StringBuilder = alloc(sb_new())
    sb_push(b, "use the qualified form '")
    sb_push(b, en)
    sb_push_char(b, 46)
    sb_push(b, v)
    sb_push(b, "' to construct an enum value; the unqualified variant name is not a constructor")
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    return out
}

func enum_method_msg(en: string, mname: string) -> string {
    b: *StringBuilder = alloc(sb_new())
    sb_push_char(b, 39)
    sb_push(b, mname)
    sb_push(b, "' is not defined; methods on the enum '")
    sb_push(b, en)
    sb_push(b, "' are not supported, match on it instead")
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    return out
}

func async_name_msg(name: string) -> string {
    b: *StringBuilder = alloc(sb_new())
    sb_push_char(b, 39)
    sb_push(b, name)
    sb_push(b, "' is async; call it with await or start it with async_run")
    out: string = substring(sb_cstr(b), 0, sb_size(b))
    sb_free(b)
    free(b)
    return out
}

func infer_async_run(tc: *TypeChecker, arg_off: int64, arg_len: int64, lo: int64, hi: int64) -> int64 {
    if (*tc).in_async {
        tc_emit(tc, "async_run cannot be called inside an async func; await the call instead", lo, hi)
    }
    a: *Ast = (*tc).ast
    mut async_name: string = ""
    if arg_len == 1 {
        first_id: int64 = vec_get((*a).kids, arg_off)
        first: ExprNode = vec_get((*a).exprs, first_id)
        if first.kind == xk_call() {
            callee: ExprNode = vec_get((*a).exprs, first.a)
            if callee.kind == xk_ident() {
                name: string = ast_name(a, callee.a)
                asyncs: *Map<int64> = (*tc).async_fns
                if map_has(asyncs, name) && !is_local(tc, name) {
                    async_name = name
                }
            }
        }
    }
    if str_len(async_name) > 0 {
        asyncs2: *Map<int64> = (*tc).async_fns
        return unwrap_or(map_get(asyncs2, async_name), ty_unknown((*tc).ty))
    }
    tc_emit(tc, "async_run takes a direct call of an async func, written at the call site", lo, hi)
    return ty_unknown((*tc).ty)
}

func infer_call_args(tc: *TypeChecker, off: int64, len: int64) -> *Vector<int64> {
    out: *Vector<int64> = alloc(vec_new())
    a: *Ast = (*tc).ast
    mut i: int64 = 0
    while i < len {
        vec_push(out, infer_expr(tc, vec_get((*a).kids, off + i)))
        i = i + 1
    }
    return out
}

