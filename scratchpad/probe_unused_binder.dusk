@paradigm procedural
@import std.vector

enum E {
    A,
    B(x: bool),
    C(y: int64),
}

func kind(e: *E) -> int64 {
    match *e {
        A => { return 0 }
        B(x) => { return 1 }
        C(y) => { return 2 }
    }
    return -1
}

func main() -> int32 {
    e: *E = alloc(E.B(true))
    println(kind(e))
    free(e)
    return 0
}
